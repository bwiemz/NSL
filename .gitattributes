# Snapshot files compared byte-for-byte via include_str! / insta must
# have deterministic line endings regardless of checkout platform.
# Without this, Windows core.autocrlf=true normalizes LF to CRLF on
# checkout and every snapshot assertion that compares against an
# emitter using `ptx.push_str("...\n")` fails.
*.snap text eol=lf
*.sh text eol=lf

# Committed CPDT calibration fixtures are binary safetensors; mark as such
# so git skips text-diff heuristics and CRLF normalization.
tests/fixtures/cpdt_calibration/*.safetensors binary
