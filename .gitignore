/.serena
/target/
.nsl-cache/
/.VSCodeCounter/
*.exe
*.o
.worktrees/
desktop.ini

# Spec and plan docs (tracked locally, not in repo)
docs/superpowers/specs/
docs/superpowers/plans/
docs/plans/

# Coder-RL generated data (rebuild with build_tokenizer.py + prepare_sft.py)
models/coder-rl/data/sft_tokens.bin
models/coder-rl/data/sft_labels.bin
models/coder-rl/data/tokenizer/
models/coder-rl/checkpoints/

# Coder-50m generated data
models/coder50m/data/*.bin
models/coder50m/data/tokenizer/

# Compiled NSL build artifacts (regenerated from .nsl sources)
*.exp
*.lib
*.nslm

# Test-generated profiling manifests (written by `nsl run --monitor`; contain
# absolute local paths and are regenerated on each test run).
*.nsl-profile.json

# Model binaries (regenerated from training)
*.onnx
*.safetensors
# Exception: committed CPDT calibration fixtures (deterministic, seed-anchored).
!tests/fixtures/cpdt_calibration/*.safetensors
# Exception: committed WGGO merge-gate fixtures (deterministic, seed-anchored).
!tests/fixtures/wggo_calib_data.safetensors
!tests/fixtures/wggo_calib_weights.safetensors

# Log files (per-run, never versioned)
*.log

# Insta snapshot pending-review files (accepted snapshots land as .snap)
*.snap.new

# Python bytecode
__pycache__/

# Research PDFs are versioned under docs/research/

# Claude Code / MCP plugin state
.claude/
.dist/
.playwright-mcp/
