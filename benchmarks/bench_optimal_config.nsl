# Optimal Config Sweep for NSLCoder-50M
# System: 64GB RAM + RTX 5070 Ti (16GB VRAM)

from model import NSLCoder
from nsl.nn.losses import cross_entropy

let m = NSLCoder()
print("NSLCoder-50M initialized")

let tokens = load_mmap("C:/Users/bwiem/ai testing/codeforge/data/pretokenized/150m/tokens.bin", 3)

# ── Config 1: batch=1, seq=512 ──
let loader1 = DataLoader(tokens, batch_size=1, seq_len=512, shuffle=false, drop_last=true)
alloc_reset()
let t0 = clock()
let s1 = 0
for batch in loader1:
    let logits = m.forward_train(batch.input_ids, false)
    s1 = s1 + 1
    if s1 >= 3:
        break
let t1 = clock()
print("batch=1 seq=512: " + str((t1 - t0) * 1000.0 / 3.0) + " ms/step, " + str(3.0 * 512.0 / (t1 - t0)) + " tok/s")

# ── Config 2: batch=1, seq=1024 ──
