    let logits = m.forward_train(batch.input_ids, false)
    s2 = s2 + 1
    if s2 >= 3:
        break
let t3 = clock()
print("batch=1 seq=1024: " + str((t3 - t2) * 1000.0 / 3.0) + " ms/step, " + str(3.0 * 1024.0 / (t3 - t2)) + " tok/s")

