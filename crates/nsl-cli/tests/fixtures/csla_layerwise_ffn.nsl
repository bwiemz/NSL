# CSLA Stage-2 (D1a) parity fixture: blocks-structured FFN LM, packing-free.
#
# A miniature 2-block residual-FFN language model (embedding + tied LM head +
# rmsnorm — deliberately attention-free so the gate isolates the
# window-buffered schedule from flash/packing machinery; the packed-GQA
# composition has its own fixture, csla_layerwise_packed_gqa.nsl).
#
# Sized for the D1a window semantics:
#   - 1664 tokens / (batch 2 x seq 64) = 13 micro-batches per epoch;
#   - grad_accumulation=2 -> epochs=1 gives 6 optimizer steps + ONE trailing
#     partial window (exercises the teardown sweep: buffered saves + batch
#     dict of the tail must be swept, and the tail must not step — exactly
#     like the baseline's discarded m_partial);
#   - the harness rewrites "epochs=1" -> "epochs=2" for the straddle case:
#     window 7 then spans the epoch boundary (micro-batches 13 + 14), which
#     the global step counter's modulo handles identically to the baseline.
#
# Marker rewrites (exact string match by the harness):
#   - "# GPU_PLACEMENT" -> "m.to(cuda)" for GPU runs;
#   - "CSLA_SAVE_PATH"  -> the temp .nslm path;
#   - "epochs=1"        -> "epochs=2" for the epoch-straddle case;
#   - "grad_accumulation=2)" -> "grad_accumulation=2, grad_clip=1.0)" for the
#     refusal test.
#
# No bias params anywhere: broadcast-add bias grads hit the pre-existing
# FASE-accumulate shape abort (tensor/mod.rs len assert) on BOTH arms.

from nsl.nn.losses import cross_entropy

model Blk:
    norm_f: Tensor = ones([64])
    w_up: Tensor = randn([64, 128]) * 0.15
    w_down: Tensor = randn([128, 64]) * 0.15

    fn forward(self, h: Tensor) -> Tensor:
        let f = (rmsnorm(h, self.norm_f, 0.00001) @ self.w_up) @ self.w_down
        return h + f

model TinyLM:
    embed: Tensor = randn([64, 64]) * 0.1
    blocks: [Blk; 2] = Blk()
    norm_out: Tensor = ones([64])

    fn forward_train(self, input_ids: Tensor) -> Tensor:
        let ids_shape = input_ids.shape
        let batch_size = ids_shape[0]
        let seq_len = ids_shape[1]
        let flat_ids = input_ids.reshape([batch_size * seq_len])
        let emb = embedding_lookup(self.embed, flat_ids)
        let h = emb.reshape([batch_size, seq_len, 64])
        for block in self.blocks:
            h = block.forward(h)
        let hn = rmsnorm(h, self.norm_out, 0.00001)
        return hn @ self.embed.transpose(0, 1)

let m = TinyLM()
# GPU_PLACEMENT

# 208 units of 8 tokens (1..7 then 0) = 1664 tokens = 13 exact micro-batches.
let unit = tensor_cat([arange(7) + full([7], 1.0), zeros([1])], 0)
let tokens = unit.reshape([1, 8]).expand([208, 8]).contiguous().reshape([1664])
let loader = DataLoader(tokens, batch_size=2, seq_len=64, shuffle=false, drop_last=true)

print("LOSS_STREAM_BEGIN")

train(model=m, epochs=1, grad_accumulation=2):
    optimizer: AdamW(lr=0.002, weight_decay=0.01, beta1=0.9, beta2=0.95, eps=1e-8)
    step(batch):
        let logits = m.forward_train(batch.input_ids)
        let ls = logits.shape
        let flat_logits = logits.reshape([ls[0] * ls[1], ls[2]])
        let flat_labels = batch.labels.reshape([ls[0] * ls[1]])
        let loss = cross_entropy(flat_logits, flat_labels)
    callbacks:
        on_step(step, loss):
            print(loss)

print("LOSS_STREAM_END")

# D1b memory-win probe (GPU runs): peak bytes ever allocated under the
# MPartial surface (tag 4). Baseline allocates the FULL m_partial window
# up front; the layerwise schedule's peak is max(one layer) + epilogue
# globals. 0 on CPU runs (no GPU allocator) — the surface gate is GPU-only.
print("MPARTIAL_PEAK_BEGIN")
print(gpu_surface_peak_bytes(4))
print("MPARTIAL_PEAK_END")

model_save(m, "CSLA_SAVE_PATH")
