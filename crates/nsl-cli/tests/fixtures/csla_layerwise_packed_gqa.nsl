# CSLA Stage-2 (D1a) parity fixture: packed GQA composition.
#
# stage_c_packed_gqa.nsl's shape with grad_clip REMOVED (two-phase clip needs
# the global L2 norm over the full m_partial window, which --layerwise-accum
# refuses by design).
#
# Gate roles:
#   - CPU PARITY (--target cpu -> empty variant table -> attention
#     decomposes at compile time): packed dict buffering (segment_ids /
#     position_ids / input_ids per micro-batch), the per-b packing-registry
#     re-install, and the packed EmbeddingBackward reading buffered
#     input_ids at replay time;
#   - GPU PARITY, two distinct attention-backward paths (the [csla] lse
#     tape-carry stderr line names which one ran; gates assert it exactly):
#       * Block policy (--checkpoint-blocks alone): SDPA outs are recompute
#         victims — the replay's spliced clone RE-LAUNCHES the fused
#         forward per micro-batch and re-establishes the Value-keyed aux
#         locally; the LSE carry is INERT (0 slots). The GQA form's
#         expanded strided K/V declines the fused launch at runtime; the
#         harness's MHA rewrite (kv_heads == heads) makes it FIRE, proven
#         by the sdpa_fused_launch_count markers below.
#       * Selective policy (+ --checkpoint-selective): SDPA outs are SAVED
#         -> adjoint imports -> the save phase buffers the aux entries
#         (2 slots) and the replay re-binds each micro-batch's REAL
#         forward-saved logsumexp into the fused phase-2 backward — the
#         live tape-carry configuration.
#
# 2048 tokens / (batch 2 x seq 64) = 16 micro-batches; grad_accumulation=2
# -> 8 optimizer steps, no trailing partial window.
#
# Marker rewrites: "# GPU_PLACEMENT" -> "m.to(cuda)"; "CSLA_SAVE_PATH".

from nsl.nn.gqa import GroupedQueryAttention
from nsl.nn.losses import cross_entropy

model Blk:
    norm_a: Tensor = ones([64])
    norm_f: Tensor = ones([64])
    attn: GroupedQueryAttention = GroupedQueryAttention(64, 2, 1, 32, 0.0)
    w_up: Tensor = randn([64, 128]) * 0.15
    w_down: Tensor = randn([128, 64]) * 0.15

    fn forward(self, h: Tensor, seg: Tensor, pos: Tensor, training: bool) -> Tensor:
        let a = self.attn.forward_packed(rmsnorm(h, self.norm_a, 0.00001), seg, pos, training)
        let h1 = h + a
        let f = (rmsnorm(h1, self.norm_f, 0.00001) @ self.w_up) @ self.w_down
        return h1 + f

model PackedLM:
    embed: Tensor = randn([64, 64]) * 0.1
    blocks: [Blk; 2] = Blk()
    norm_out: Tensor = ones([64])

    fn forward_train(self, input_ids: Tensor, seg: Tensor, pos: Tensor, training: bool) -> Tensor:
        let ids_shape = input_ids.shape
        let batch_size = ids_shape[0]
        let seq_len = ids_shape[1]
        let flat_ids = input_ids.reshape([batch_size * seq_len])
        let emb = embedding_lookup(self.embed, flat_ids)
        let h = emb.reshape([batch_size, seq_len, 64])
        for block in self.blocks:
            h = block.forward(h, seg, pos, training)
        let hn = rmsnorm(h, self.norm_out, 0.00001)
        return hn @ self.embed.transpose(0, 1)

let m = PackedLM()
# GPU_PLACEMENT

# Token stream with real document boundaries: tokens cycle 1..7 with a 0
# (the pack separator) every 8 positions -> every 64-token window packs 8
# documents; the block-diagonal mask and segment ids have real structure.
# 16 DISTINCT micro-batch blocks (content (1..7)+k, PACK SEPARATOR 0
# preserved at every 8th position) — see the ffn fixture note on per-b
# slot-binding vacuity under identical micro-batches.
let u0 = tensor_cat([arange(7) + full([7], 1.0), zeros([1])], 0)
let b0 = u0.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u1 = tensor_cat([arange(7) + full([7], 2.0), zeros([1])], 0)
let b1 = u1.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u2 = tensor_cat([arange(7) + full([7], 3.0), zeros([1])], 0)
let b2 = u2.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u3 = tensor_cat([arange(7) + full([7], 4.0), zeros([1])], 0)
let b3 = u3.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u4 = tensor_cat([arange(7) + full([7], 5.0), zeros([1])], 0)
let b4 = u4.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u5 = tensor_cat([arange(7) + full([7], 6.0), zeros([1])], 0)
let b5 = u5.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u6 = tensor_cat([arange(7) + full([7], 7.0), zeros([1])], 0)
let b6 = u6.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u7 = tensor_cat([arange(7) + full([7], 8.0), zeros([1])], 0)
let b7 = u7.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u8 = tensor_cat([arange(7) + full([7], 9.0), zeros([1])], 0)
let b8 = u8.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u9 = tensor_cat([arange(7) + full([7], 10.0), zeros([1])], 0)
let b9 = u9.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u10 = tensor_cat([arange(7) + full([7], 11.0), zeros([1])], 0)
let b10 = u10.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u11 = tensor_cat([arange(7) + full([7], 12.0), zeros([1])], 0)
let b11 = u11.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u12 = tensor_cat([arange(7) + full([7], 13.0), zeros([1])], 0)
let b12 = u12.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u13 = tensor_cat([arange(7) + full([7], 14.0), zeros([1])], 0)
let b13 = u13.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u14 = tensor_cat([arange(7) + full([7], 15.0), zeros([1])], 0)
let b14 = u14.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u15 = tensor_cat([arange(7) + full([7], 16.0), zeros([1])], 0)
let b15 = u15.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let tokens = tensor_cat([b0, b1, b2, b3, b4, b5, b6, b7, b8, b9, b10, b11, b12, b13, b14, b15], 0).reshape([2048])
let loader = DataLoader(tokens, batch_size=2, seq_len=64, shuffle=false, drop_last=true, packing=true, pack_separator=0, emit_attention_mask=false)

print("LOSS_STREAM_BEGIN")

train(model=m, epochs=1, grad_accumulation=2):
    optimizer: AdamW(lr=0.002, weight_decay=0.0, beta1=0.9, beta2=0.95, eps=1e-8)
    step(batch):
        let pos = batch.position_ids
        let logits = m.forward_train(batch.input_ids, batch.segment_ids, pos, false)
        let ls = logits.shape
        let flat_logits = logits.reshape([ls[0] * ls[1], ls[2]])
        let flat_labels = batch.labels.reshape([ls[0] * ls[1]])
        let loss = cross_entropy(flat_logits, flat_labels)
    callbacks:
        on_step(step, loss):
            print(loss)

print("LOSS_STREAM_END")

# Fused-SDPA launch counter (variant 0 = base fused forward kernel): 0 when
# every launch declined (GQA strided K/V, or CPU target), > 0 when the fused
# path fired — the MHA GPU gate asserts equality across arms and > 0.
print("SDPA_FUSED_BEGIN")
print(sdpa_fused_launch_count(0))
print("SDPA_FUSED_END")

model_save(m, "CSLA_SAVE_PATH")
