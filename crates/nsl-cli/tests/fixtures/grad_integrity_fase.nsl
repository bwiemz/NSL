# P0.3 grad-integrity fixture (FASE-Deferred path — grad_accumulation>=2 with
# AdamW/source-AD, so gradients are consumed during backward lowering and the
# gate is fed per-parameter via step_begin/note/step_end). A no-bias 2-layer
# gelu MLP = 2 trainable params (no shared-intermediate bias, so the FASE
# optimizer hook does not drop any gradient).
from nsl.nn.losses import mse_loss

model Net:
    w1: Tensor = randn([4, 8]) * 0.1
    w2: Tensor = randn([8, 4]) * 0.1

    fn forward(self, x: Tensor) -> Tensor:
        return gelu(x @ self.w1) @ self.w2

let m = Net()
let x = randn([4, 4]) * 0.1
let y = randn([4, 4]) * 0.1

print("LOSS_STREAM_BEGIN")
train(model=m, epochs=12, grad_accumulation=4):
    optimizer: AdamW(lr=0.01, beta1=0.9, beta2=0.999, eps=1e-8, weight_decay=0.0)
    step(batch):
        let pred = m.forward(x)
        let loss = mse_loss(pred, y)
    callbacks:
        on_step(step, loss):
            print(loss)
print("LOSS_STREAM_END")
