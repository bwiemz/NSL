# P5 Muon: Newton-Schulz probe. Prints three scalar statistics of
# muon_orthogonalize's output on a fixed, full-rank, NON-degenerate input
# (sqrt ramp shifted to signed values — sqrt is IEEE-exact so the Rust
# reference matches bit-for-bit; a constant/linear probe would be low-rank
# and could pass vacuously). The gate pins the stats against an independent
# f64 reference implementation in Rust.
#
# Also probes the tall case (rows > cols) through the transpose branch.

from nsl.optim.muon import muon_orthogonalize
from nsl.optim.muon import muon_step

# Wide: 4x6 (rows <= cols, no transpose)
let g = (sqrt(arange(24) * 1.7 + full([24], 0.3)) - full([24], 1.5)).reshape([4, 6])
let o = muon_orthogonalize(g, 5.0)
print("WIDE_BEGIN")
print(sum(o).item())
print(sum(o * o).item())
let r = o @ o.transpose(0, 1)
print(sum(r * r).item())
print("WIDE_END")

# Tall: 6x4 (transpose branch)
let gt = (sqrt(arange(24) * 2.3 + full([24], 0.7)) - full([24], 2.0)).reshape([6, 4])
let ot = muon_orthogonalize(gt, 5.0)
print("TALL_BEGIN")
print(sum(ot).item())
print(sum(ot * ot).item())
let rt = ot.transpose(0, 1) @ ot
print(sum(rt * rt).item())
print("TALL_END")

# Full Muon-arm step pin (review L9): two muon_step calls on a tall 4x3
# param with a CONSTANT gradient exercise the momentum accumulate, the
# nesterov combine (uses the UPDATED buffer), the sqrt(rows/cols) scale
# and the decoupled weight decay — a sign or order error in any of them
# moves these stats at O(1e-2)+.
let p = (sqrt(arange(12) * 1.3 + full([12], 0.5)) - full([12], 1.2)).reshape([4, 3])
let gr = (sqrt(arange(12) * 0.9 + full([12], 0.9)) - full([12], 1.0)).reshape([4, 3])
let mbuf = zeros([4, 3])
let vbuf = zeros([4, 3])
muon_step(p, gr, mbuf, vbuf, 0.0, 0.02, 0.95, 0.9, 0.999, 0.00000001, 0.01, true, 5.0, 1.0)
muon_step(p, gr, mbuf, vbuf, 0.0, 0.02, 0.95, 0.9, 0.999, 0.00000001, 0.01, true, 5.0, 2.0)
print("STEP_BEGIN")
print(sum(p).item())
print(sum(p * p).item())
print(sum(mbuf).item())
print("STEP_END")
