# P1 Muon item 6: parameter-ROLE routing fixture. Three rank-2 params whose
# NAMES would have misrouted under the old substring list, now routed by role:
#   - tok_table   : the REAL embedding, named outside the old exclusion list
#                   (pre-roles it silently took the Muon route) — inferred
#                   role=embedding from its embedding_lookup usage.
#   - embed_proj  : a hidden weight whose name CONTAINS "embed" (pre-roles it
#                   was silently AdamW-routed) — role=hidden by default.
#   - out_proj    : an UNTIED lm_head, structurally invisible in v1 —
#                   @param_role("head") routes it to AdamW explicitly.
#   - norm_out    : rank-1, role=vector by declared rank.
#
# Marker rewrites: "MUON_SAVE_PATH" -> temp .nslm path.

from nsl.nn.losses import cross_entropy

model RoleLM:
    tok_table: Tensor = randn([32, 32]) * 0.1
    embed_proj: Tensor = randn([32, 32]) * 0.1
    @param_role("head")
    out_proj: Tensor = randn([32, 32]) * 0.1
    norm_out: Tensor = ones([32])

    fn forward_train(self, input_ids: Tensor) -> Tensor:
        let ids_shape = input_ids.shape
        let batch_size = ids_shape[0]
        let seq_len = ids_shape[1]
        let flat_ids = input_ids.reshape([batch_size * seq_len])
        let emb = embedding_lookup(self.tok_table, flat_ids)
        let h = emb.reshape([batch_size, seq_len, 32])
        let h2 = h @ self.embed_proj
        let hn = rmsnorm(h2, self.norm_out, 0.00001)
        return hn @ self.out_proj

let m = RoleLM()

let u0 = tensor_cat([arange(7) + full([7], 1.0), zeros([1])], 0)
let b0 = u0.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u1 = tensor_cat([arange(7) + full([7], 2.0), zeros([1])], 0)
let b1 = u1.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u2 = tensor_cat([arange(7) + full([7], 3.0), zeros([1])], 0)
let b2 = u2.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let u3 = tensor_cat([arange(7) + full([7], 4.0), zeros([1])], 0)
let b3 = u3.reshape([1, 8]).expand([16, 8]).contiguous().reshape([1, 128])
let tokens = tensor_cat([b0, b1, b2, b3], 0).reshape([512])
let loader = DataLoader(tokens, batch_size=2, seq_len=64, shuffle=false, drop_last=true)

print("LOSS_STREAM_BEGIN")

train(model=m, epochs=1):
    optimizer: Muon(lr=0.002, momentum=0.95, nesterov=true, ns_steps=5, weight_decay=0.01, beta1=0.9, beta2=0.95, eps=1e-8)
    step(batch):
        let logits = m.forward_train(batch.input_ids)
        let ls = logits.shape
        let flat_logits = logits.reshape([ls[0] * ls[1], ls[2]])
        let flat_labels = batch.labels.reshape([ls[0] * ls[1]])
        let loss = cross_entropy(flat_logits, flat_labels)
    callbacks:
        on_step(step, loss):
            print(loss)

print("LOSS_STREAM_END")
model_save(m, "MUON_SAVE_PATH")
