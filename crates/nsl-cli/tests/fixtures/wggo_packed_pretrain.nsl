# WGGO-orchestrated PACKED pretraining E2E (campaign PR-8).
#
# A miniature GQA transformer trained on a packed token stream:
#   - DataLoader(packing=true) builds PackedBatch dicts at runtime:
#     input_ids / labels / attention_mask ([b, seq, seq] additive,
#     block-diagonal causal-within-doc, 0 attend / -1e9 blocked).
#   - The model consumes the mask through the stdlib GQA forward_masked
#     (PCA Stage B: scaled_dot_product_attention_masked, decomposed
#     source-AD backward).
#   - Driven with --pretrain-optimized (source AD + wggo greedy + csha
#     auto): WGGO pre-plans per-layer decisions; the masked-attention call
#     makes the module packing-capable, so the plan may select
#     packing_mode=segment_id (Stage D honesty).
#
# The harness asserts: loss decreases from the uniform-CE baseline, the
# WGGO plan is consumed, and no packing-rejection noise appears.

from nsl.nn.gqa import GroupedQueryAttention
from nsl.nn.losses import cross_entropy

model Blk:
    norm_a: Tensor = ones([16])
    norm_f: Tensor = ones([16])
    attn: GroupedQueryAttention = GroupedQueryAttention(16, 2, 1, 8, 0.0)
    w_up: Tensor = randn([16, 32]) * 0.25
    w_down: Tensor = randn([32, 16]) * 0.25

    fn forward(self, h: Tensor, mask: Tensor, training: bool) -> Tensor:
        let a = self.attn.forward_masked(rmsnorm(h, self.norm_a, 0.00001), mask, training)
        let h1 = h + a
        let f = (rmsnorm(h1, self.norm_f, 0.00001) @ self.w_up) @ self.w_down
        return h1 + f

model PackedLM:
    embed: Tensor = randn([64, 16]) * 0.1
    blocks: [Blk; 2] = Blk()
    norm_out: Tensor = ones([16])

    fn forward_train(self, input_ids: Tensor, mask: Tensor, training: bool) -> Tensor:
        let ids_shape = input_ids.shape
        let batch_size = ids_shape[0]
        let seq_len = ids_shape[1]
        let flat_ids = input_ids.reshape([batch_size * seq_len])
        let emb = embedding_lookup(self.embed, flat_ids)
        let h = emb.reshape([batch_size, seq_len, 16])
        for block in self.blocks:
            h = block.forward(h, mask, training)
        let hn = rmsnorm(h, self.norm_out, 0.00001)
        # Weight-tied LM head
        return hn @ self.embed.transpose(0, 1)

let m = PackedLM()

# Token stream with real document boundaries: tokens cycle 1..7 with a 0
# (the pack separator) every 8 positions, so every 16-token window packs
# two documents and the block-diagonal mask has real structure.
let unit = tensor_cat([arange(7) + full([7], 1.0), zeros([1])], 0)
let tokens = unit.reshape([1, 8]).expand([128, 8]).contiguous().reshape([1024])
let loader = DataLoader(tokens, batch_size=2, seq_len=16, shuffle=false, drop_last=true, packing=true, pack_separator=0)

print("LOSS_STREAM_BEGIN")

train(model=m, epochs=2, grad_accumulation=2, grad_clip=1.0):
    optimizer: AdamW(lr=0.003, weight_decay=0.0, beta1=0.9, beta2=0.95, eps=1e-8)
    step(batch):
        let logits = m.forward_train(batch.input_ids, batch.attention_mask, false)
        let ls = logits.shape
        let flat_logits = logits.reshape([ls[0] * ls[1], ls[2]])
        let flat_labels = batch.labels.reshape([ls[0] * ls[1]])
        let loss = cross_entropy(flat_logits, flat_labels)
    callbacks:
        on_step(step, loss):
            print(loss)

print("LOSS_STREAM_END")
