from nsl.nn.losses import mse_loss

model Tiny:
    w: Tensor = ones([4, 4])

    fn forward(self, x: Tensor) -> Tensor:
        return x @ self.w

let m = Tiny()
let x = ones([2, 4])
let y = zeros([2, 4])

train(model = m, epochs = 2, grad_accumulation = 4):
    optimizer: AdamW(lr = 0.001, weight_decay = 0.01)
    step(batch):
        let pred = m.forward(x)
        let loss = mse_loss(pred, y)
    callbacks:
        on_step(step, loss):
            print(loss)
