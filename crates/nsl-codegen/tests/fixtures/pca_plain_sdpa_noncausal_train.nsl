# PCA Stage B backward differential, plain side (the oracle): identical
# model/data/optimizer to pca_masked_sdpa_zero_mask_train.nsl but through
# plain non-causal SDPA (fused op + FlashAttentionBackwardExtract backward).

from nsl.nn.losses import mse_loss

model Attn:
    wq: Tensor = ones([2, 2])
    wk: Tensor = ones([2, 2]) * 0.5
    wv: Tensor = ones([2, 2]) * 0.25

    fn forward(self, x: Tensor) -> Tensor:
        let q = (x @ self.wq).reshape([1, 1, 4, 2])
        let k = (x @ self.wk).reshape([1, 1, 4, 2])
        let v = (x @ self.wv).reshape([1, 1, 4, 2])
        return scaled_dot_product_attention(q, k, v, 0.7071, false)

let m = Attn()
let x = arange(8).reshape([4, 2]) * 0.1
let y = zeros([1, 1, 4, 2])

train(model = m, epochs = 4):
    optimizer: SGD(lr = 0.01)
    step(batch):
        let out = m.forward(x)
        let loss = mse_loss(out, y)

model_save(m, "plain_sdpa_out.nslm")
