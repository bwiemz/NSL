# name and (b) emits the `dfs_enter_ptr`/`dfs_exit_ptr` parameters +
# DFS-enter/DFS-exit ancestor check in PTX.
#
# Body is intentionally trivial — the integration test only inspects
# the compile context, the synthesized kernel name, and the PTX byte
# stream, none of which depend on the function body.

@flash_attention
@tree_mask
fn forward():
    pass
