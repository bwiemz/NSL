    fma.rn.f32 %f_acc_K_0, %f_x_K_0, %f_w_K_0, %f_acc_K_0;
    add.u32 %r_indim_K_0, %r_indim_K_0, 1;
    setp.lt.u32 %p_indim_K_0, %r_indim_K_0, 32;
    @%p_indim_K_0 bra V2_CSHA_PROJ_K_INDIM_0_7;
    cvt.rn.f16.f32 %h_out_K_0, %f_acc_K_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %k_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_K_0;
V2_K_PREPASS_SKIP_7:
    bar.sync 0; // K tile complete; safe for all S-computes
    // CSHA RoPE K rotation (fused path): block_kv=32, head_dim=32, pairs_per_lane=4
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_K_FUSED_SKIP;
    // A.2.4 RoPE K sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_K_LOOP_0:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_K_END_0;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %k_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %k_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %k_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %k_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_K_LOOP_0;
V2_CSHA_ROPE_K_END_0:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_K_FUSED_SKIP:
    bar.sync 0;  // FENCE: K RoPE rotation writes visible to all threads
    // CSHA S-compute pass
    // ====== q_tile_iter = 0 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=0
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_0;
    add.u32 %r_indim_Q_0, %warp_id, 0; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=0), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_0:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_0:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_0;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_0:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=0, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_0;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_0:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_0;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_0;
V2_CSHA_ROPE_Q_END_0:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_0:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 0
    add.u32 %r0, %warp_id, 0;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_0:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_0; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_0:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_0;
V2_K_LOAD_SKIP_0:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 0)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_0:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 0;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 4096;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_0;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 4096;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 4096;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_0;
    // Save softmax state for q_tile_iter=0 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18432; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 1 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=1
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_1;
    add.u32 %r_indim_Q_0, %warp_id, 4; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=1), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_1:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_1:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_1;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_1:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=1, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_1;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_1:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_1;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_1;
V2_CSHA_ROPE_Q_END_1:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_1:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 1
    add.u32 %r0, %warp_id, 4;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_1:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_1; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_1:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_1;
V2_K_LOAD_SKIP_1:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 1)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_1:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 4;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 4608;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_1;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 4608;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 4608;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_1;
    // Save softmax state for q_tile_iter=1 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18440; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 2 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=2
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_2;
    add.u32 %r_indim_Q_0, %warp_id, 8; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=2), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_2:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_2:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_2;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_2:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=2, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_2;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_2:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_2;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_2;
V2_CSHA_ROPE_Q_END_2:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_2:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 2
    add.u32 %r0, %warp_id, 8;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_2:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_2; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_2:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_2;
V2_K_LOAD_SKIP_2:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 2)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_2:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 8;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 5120;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_2;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 5120;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 5120;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_2;
    // Save softmax state for q_tile_iter=2 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18448; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 3 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=3
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_3;
    add.u32 %r_indim_Q_0, %warp_id, 12; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=3), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_3:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_3:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_3;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_3:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=3, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_3;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_3:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_3;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_3;
V2_CSHA_ROPE_Q_END_3:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_3:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 3
    add.u32 %r0, %warp_id, 12;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_3:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_3; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_3:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_3;
V2_K_LOAD_SKIP_3:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 3)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_3:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 12;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 5632;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_3;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 5632;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 5632;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_3;
    // Save softmax state for q_tile_iter=3 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18456; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 4 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=4
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_4;
    add.u32 %r_indim_Q_0, %warp_id, 16; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=4), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_4:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_4:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_4;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_4:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=4, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_4;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_4:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_4;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_4;
V2_CSHA_ROPE_Q_END_4:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_4:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 4
    add.u32 %r0, %warp_id, 16;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_4:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_4; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_4:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_4;
V2_K_LOAD_SKIP_4:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 4)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_4:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 16;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 6144;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_4;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 6144;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 6144;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_4;
    // Save softmax state for q_tile_iter=4 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18464; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 5 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=5
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_5;
    add.u32 %r_indim_Q_0, %warp_id, 20; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=5), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_5:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_5:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_5;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_5:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=5, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_5;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_5:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_5;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_5;
V2_CSHA_ROPE_Q_END_5:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_5:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 5
    add.u32 %r0, %warp_id, 20;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_5:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_5; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_5:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_5;
V2_K_LOAD_SKIP_5:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 5)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_5:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 20;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 6656;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_5;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 6656;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 6656;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_5;
    // Save softmax state for q_tile_iter=5 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18472; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 6 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=6
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_6;
    add.u32 %r_indim_Q_0, %warp_id, 24; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=6), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_6:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_6:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_6;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_6:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=6, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_6;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_6:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_6;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_6;
V2_CSHA_ROPE_Q_END_6:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_6:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 6
    add.u32 %r0, %warp_id, 24;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_6:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_6; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_6:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_6;
V2_K_LOAD_SKIP_6:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 6)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_6:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 24;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 7168;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_6;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 7168;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 7168;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_S_6;
    // Save softmax state for q_tile_iter=6 (warp-indexed)
    cvt.u64.u32 %rd_wt_off, %warp_id;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // warp_id * iters * 8
    add.u64 %rd_wt_dst, %shmem_base, 18480; // save_base + q_tile_iter*8
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.f32 [%rd_wt_dst], %row_max;
    add.u64 %rd_wt_dst, %rd_wt_dst, 4;
    st.shared.f32 [%rd_wt_dst], %row_sum;
    // ====== q_tile_iter = 7 / 8 (S-pass) ======
    mov.f32 %row_max, 0fFF800000;
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;
    // Q-only projection sweep q_tile_iter=7
    ld.param.u64 %rd60, [csha_wq_ptr];
    setp.eq.u64 %p0, %rd60, 0;
    @%p0 bra V2_Q_ONLY_PROJ_SKIP_7;
    add.u32 %r_indim_Q_0, %warp_id, 28; // warp_row = warp_id + iter*4
    cvt.u64.u32 %warp_row, %r_indim_Q_0;
    mov.u64 %q_smem_base, %shmem_base;
    add.u64 %k_smem_base, %shmem_base, 2048;
    add.u64 %v_smem_base, %shmem_base, 2048;
    add.u64 %q_tile, %shmem_base, 8192;
    add.u64 %k_tile, %shmem_base, 10240;
    add.u64 %v_tile, %shmem_base, 12288;
    ld.param.u64 %x_norm_base, [csha_x_ptr];
    mul.lo.u64 %rd_wt_off, %head_idx, %rd6;
    add.u64 %rd_wt_off, %rd_wt_off, %q_start;
    add.u64 %rd_wt_off, %rd_wt_off, %warp_row;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, %rd7;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;
    add.u64 %x_norm_base, %x_norm_base, %rd_wt_off;
    // A.2.3 warp-per-row sweep: Q (q_tile_iter=7), slices/lane=1
V2_CSHA_PROJ_Q_LOOP_7:
    mov.f32 %f_acc_Q_0, 0f00000000;    // acc[Q][0] = 0
    mov.u32 %r_indim_Q_0, 0;           // in_dim loop counter
V2_CSHA_PROJ_Q_INDIM_0_7:
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    shl.b64 %rd_wt_off, %rd_wt_off, 2;    // in_dim * 4 bytes (f32)
    add.u64 %rd_wt_src, %x_norm_base, %rd_wt_off;
    ld.global.f32 %f_x_Q_0, [%rd_wt_src];
    cvt.u64.u32 %rd_wt_off, %r_indim_Q_0;
    mul.lo.u64 %rd_wt_off, %rd_wt_off, 64; // in_dim * head_dim * 2 (f16 W row-stride)
    add.u64 %rd_wt_dst, %q_tile, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1; // * 2 bytes (f16)
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    ld.shared.b16 %h_w_Q_0, [%rd_wt_dst];
    cvt.f32.f16 %f_w_Q_0, %h_w_Q_0;
    fma.rn.f32 %f_acc_Q_0, %f_x_Q_0, %f_w_Q_0, %f_acc_Q_0;
    add.u32 %r_indim_Q_0, %r_indim_Q_0, 1;
    setp.lt.u32 %p_indim_Q_0, %r_indim_Q_0, 32;
    @%p_indim_Q_0 bra V2_CSHA_PROJ_Q_INDIM_0_7;
    cvt.rn.f16.f32 %h_out_Q_0, %f_acc_Q_0;
    mul.lo.u64 %rd_wt_off, %warp_row, 64;
    add.u64 %rd_wt_dst, %q_smem_base, %rd_wt_off;
    cvt.u64.u32 %rd_wt_off, %lane;
    shl.b64 %rd_wt_off, %rd_wt_off, 1;
    add.u64 %rd_wt_dst, %rd_wt_dst, %rd_wt_off;
    st.shared.b16 [%rd_wt_dst], %h_out_Q_0;
V2_Q_ONLY_PROJ_SKIP_7:
    bar.sync 0; // Q rows visible before Q-load
    // CSHA A.2.4: RoPE Q/K rotation epilogue (q_tile_iter=7, block_q=32, head_dim=32, pairs_per_lane=4)
    ld.param.u64 %rd_rope_cos, [cos_ptr];
    ld.param.u64 %rd_rope_sin, [sin_ptr];
    setp.eq.u64 %p_rope_cos_null, %rd_rope_cos, 0;
    setp.eq.u64 %p_rope_sin_null, %rd_rope_sin, 0;
    or.pred %p_rope_skip, %p_rope_cos_null, %p_rope_sin_null;
    @%p_rope_skip bra V2_CSHA_ROPE_SKIP_7;
    // A.2.4 RoPE Q sweep: block_q=32, half_dim=16, pairs_per_lane=4
    cvt.u32.u32 %r_rope_tid, %tid_x;
    mov.u32 %r_rope_pair_idx, %r_rope_tid;
V2_CSHA_ROPE_Q_LOOP_7:
    setp.ge.u32 %p_rope_done, %r_rope_pair_idx, 512;
    @%p_rope_done bra V2_CSHA_ROPE_Q_END_7;
    div.u32 %r_rope_row,      %r_rope_pair_idx, 16;
    rem.u32 %r_rope_dim_pair, %r_rope_pair_idx, 16;
    mul.lo.u32 %r_rope_cs_off, %r_rope_row, 16;
    add.u32 %r_rope_cs_off, %r_rope_cs_off, %r_rope_dim_pair;
    cvt.u64.u32 %rd_rope_cs_idx, %r_rope_cs_off;
    shl.b64 %rd_rope_cs_idx, %rd_rope_cs_idx, 1;  // *2 for f16
    add.u64 %rd_rope_addr, %rd_rope_cos, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_cos, %h_rope_pair;
    add.u64 %rd_rope_addr, %rd_rope_sin, %rd_rope_cs_idx;
    ld.global.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_sin, %h_rope_pair;
    mul.lo.u32 %r_rope_smem_row_off, %r_rope_row, 64;
    shl.b32 %r_rope_x0_col, %r_rope_dim_pair, 2;  // 4*dim_pair
    add.u32 %r_rope_x0_off, %r_rope_smem_row_off, %r_rope_x0_col;
    add.u32 %r_rope_x1_off, %r_rope_x0_off, 2;    // +2 bytes
    cvt.u64.u32 %rd_rope_x0_off, %r_rope_x0_off;
    cvt.u64.u32 %rd_rope_x1_off, %r_rope_x1_off;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x0, %h_rope_pair;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    ld.shared.b16 %h_rope_pair, [%rd_rope_addr];
    cvt.f32.f16 %f_rope_x1, %h_rope_pair;
    mov.f32 %f_rope_y0, 0f00000000;
    fma.rn.f32 %f_rope_y0, %f_rope_x0, %f_rope_cos, %f_rope_y0;
    neg.f32 %f_rope_neg_x1, %f_rope_x1;
    fma.rn.f32 %f_rope_y0, %f_rope_neg_x1, %f_rope_sin, %f_rope_y0;
    mov.f32 %f_rope_y1, 0f00000000;
    fma.rn.f32 %f_rope_y1, %f_rope_x0, %f_rope_sin, %f_rope_y1;
    fma.rn.f32 %f_rope_y1, %f_rope_x1, %f_rope_cos, %f_rope_y1;
    cvt.rn.f16.f32 %h_rope_y0, %f_rope_y0;
    cvt.rn.f16.f32 %h_rope_y1, %f_rope_y1;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x0_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y0;
    add.u64 %rd_rope_addr, %q_smem_base, %rd_rope_x1_off;
    st.shared.b16 [%rd_rope_addr], %h_rope_y1;
    add.u32 %r_rope_pair_idx, %r_rope_pair_idx, 128;
    bra V2_CSHA_ROPE_Q_LOOP_7;
V2_CSHA_ROPE_Q_END_7:
    bar.sync 0;  // FENCE: RoPE tile writes complete
V2_CSHA_ROPE_SKIP_7:
    bar.sync 0;  // FENCE: RoPE rotation writes visible to all threads
    // CSHA Tier C save_activations: save_activations=false, no emission
    // Phase 1: Q load, q_tile_iter = 7
    add.u32 %r0, %warp_id, 28;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    // fused_projections: Q already in SMEM; load registers from SMEM
    // slice 0 from SMEM
    cvt.u64.u32 %rd28, %lane;
    shl.b64 %rd29, %rd28, 1;  // d * 2 (f16)
    add.u64 %smem_addr, %rd23, %rd29;
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f32, %h0;  // Q[warp_row, d] f16 to f32
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;
V2_LOOP_KV_S_7:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    ld.param.u64 %rd_wk_chk, [csha_wk_ptr];
    setp.ne.u64 %p_wk_fused, %rd_wk_chk, 0;
    @%p_wk_fused bra V2_K_LOAD_SKIP_7; // K already in SMEM from projection
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_7:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_7;
V2_K_LOAD_SKIP_7:
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 7)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_7:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 28;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 7680;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_7;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 7680;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    setp.nan.f32 %p0, %f0, %f0;
    @%p0 mov.f32 %f0, 0f00000000;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 7680;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    setp.nan.f32 %p1, %f1, %f1;
    @%p1 mov.f32 %f1, 0f00000000;
    @!%p0 mov.f32 %f1, 0f00000000;
