    add.u32 %r7, %warp_id, 24;             // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd46, %r7;
    add.u64 %rd47, %q_start, %rd46;           // q_row_global
    mul.lo.u64 %rd48, %batch_idx, %rd5;       // batch*heads
    add.u64 %rd48, %rd48, %head_idx;          // + head
    mul.lo.u64 %rd48, %rd48, %rd6;            // * seq_len
    add.u64 %rd48, %rd48, %rd47;              // + q_row_global
    mul.lo.u64 %rd48, %rd48, %rd7;            // * head_dim
    shl.b64 %rd48, %rd48, 1;                  // * 2 bytes f16
    add.u64 %rd48, %rd3, %rd48;               // out_base_global
    cvt.rn.f16.f32 %h0, %f48;
    cvt.u64.u32 %rd49, %lane;
    shl.b64 %rd49, %rd49, 1;                  // * 2 bytes
    add.u64 %rd49, %rd48, %rd49;              // out_base + d*2
    st.global.b16 [%rd49], %h0;
    // LSE store (lane 0 only, null-guarded)
    setp.eq.u32 %p1, %lane, 0;
    setp.ne.u64 %p_has_lse, %logsumexp_base, 0;
    and.pred %p1, %p1, %p_has_lse;
    lg2.approx.f32 %log_sum, %row_sum;
    mov.f32 %f1, 0f3F317218;                  // ln(2)
    mul.f32 %log_sum, %log_sum, %f1;          // log_sum = ln(row_sum)
    add.f32 %lse, %row_max, %log_sum;
    mul.lo.u64 %rd50, %batch_idx, %rd5;
    add.u64 %rd50, %rd50, %head_idx;
    mul.lo.u64 %rd50, %rd50, %rd6;
    add.u64 %rd50, %rd50, %rd47;
    shl.b64 %rd50, %rd50, 2;
    add.u64 %rd50, %logsumexp_base, %rd50;
    @%p1 st.global.f32 [%rd50], %lse;
    // CSHA A5: fused_output=false, no emission
    // ====== q_tile_iter = 7 / 8 ======
    mov.f32 %row_max, 0fFF800000;              // -inf
    mov.f32 %row_sum, 0f00000000;
    mov.f32 %f48, 0f00000000;                  // O_acc[0] = 0
    // CSHA A.2.2 prologue: csha=None, no emission
    // CSHA A.2.3 projection: csha=None or fused_projections=false
    // CSHA A.2.4 RoPE epilogue: rope_q=false, no emission
    // Phase 1: Q load, q_tile_iter = 7
    add.u32 %r0, %warp_id, 28;            // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd20, %r0;                 // q_row_local as u64
    mov.u64 %rd23, 0;                    // q_offset
    mul.lo.u64 %rd24, %rd20, 32;          // q_row_local * head_dim
    shl.b64 %rd24, %rd24, 1;                  // * 2 bytes (f16)
    add.u64 %rd23, %rd23, %rd24;              // shmem row base offset
    add.u64 %rd21, %q_start, %rd20;          // q_row_global
    mul.lo.u64 %rd22, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd22, %rd22, %head_idx;         // + head_idx
    mul.lo.u64 %rd22, %rd22, %rd6;            // * seq_len
    add.u64 %rd22, %rd22, %rd21;              // + q_row_global
    mul.lo.u64 %rd22, %rd22, %rd7;            // * head_dim
    shl.b64 %rd22, %rd22, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd22, %rd0, %rd22;               // q_base global
    // slice 0: d = lane + 32*0 = lane + 0
    cvt.u64.u32 %rd28, %lane;
    add.u64 %rd28, %rd28, 0;
    shl.b64 %rd29, %rd28, 2;                  // * 4 bytes f32
    add.u64 %rd29, %rd22, %rd29;              // q_base + d*4
    ld.global.f32 %f32, [%rd29];
    cvt.rn.f16.f32 %h0, %f32;
    shl.b64 %rd30, %rd28, 1;                  // d * 2 bytes (f16)
    add.u64 %smem_addr, %rd23, %rd30;         // shmem dest
    add.u64 %smem_addr, %smem_addr, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    bar.sync 0;  // FENCE: all warps finish Q shmem store
    mov.u64 %k_start, 0;
    mov.u64 %k_max, %rd6;                        // seq_len
V2_LOOP_KV_START_7:
    // K tile load: 128 threads cooperatively load block_kv*head_dim elems
    mul.lo.u64 %rd58, %batch_idx, %rd5;      // batch*heads
    add.u64 %rd58, %rd58, %head_idx;         // + head
    mul.lo.u64 %rd58, %rd58, %rd6;            // * seq_len
    add.u64 %rd58, %rd58, %k_start;           // + k_start
    mul.lo.u64 %rd58, %rd58, %rd7;            // * head_dim
    shl.b64 %rd58, %rd58, 2;                  // * 4 bytes (f32 source)
    add.u64 %rd58, %rd1, %rd58;               // k_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_K_LOAD_7:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;                 // + kv_offset
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_K_LOAD_7;
    bar.sync 0;  // FENCE: K tile in shmem
    // Phase 2: S = Q*K^T (q_tile_iter = 7)
    mov.u32 %r1, 0;                           // k = 0
    mov.u32 %r2, 32;                           // block_kv
V2_LOOP_S_OVER_K_7:
    cvt.u64.u32 %rd32, %r1;
    mul.lo.u64 %rd32, %rd32, 32;              // k * head_dim
    shl.b64 %rd32, %rd32, 1;                  // * 2 bytes f16
    add.u64 %rd32, %rd32, 2048;                 // + kv_offset
    add.u64 %rd32, %rd32, %shmem_base;
    mov.f32 %f0, 0f00000000;                  // partial = 0
    cvt.u64.u32 %rd33, %lane;
    shl.b64 %rd33, %rd33, 1;                  // * 2 bytes f16
    add.u64 %rd33, %rd33, %rd32;              // + K row base
    ld.shared.b16 %h0, [%rd33];
    cvt.f32.f16 %f1, %h0;                     // K[k, d]
    fma.rn.f32 %f0, %f32, %f1, %f0;           // partial += Q*K
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    add.f32 %f0, %f0, %shfl_tmp;
    mul.f32 %f0, %f0, %scale;                 // S *= 1/sqrt(d_k)
    // causal: if k_global > q_row_global -> S = -inf
    cvt.u64.u32 %rd34, %r1;                   // k
    add.u64 %rd34, %rd34, %k_start;           // k_global
    add.u32 %r3, %warp_id, 28;                // q_row_local
    cvt.u64.u32 %rd35, %r3;
    add.u64 %rd35, %q_start, %rd35;            // q_row_global
    setp.gt.u64 %p0, %rd34, %rd35;
    @%p0 mov.f32 %f0, 0fFF800000;             // -inf
    setp.eq.u32 %p1, %lane, 0;
    cvt.u64.u32 %rd36, %warp_id;
    mul.lo.u64 %rd36, %rd36, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd37, %r1;
    add.u64 %rd36, %rd36, %rd37;              // + k
    shl.b64 %rd36, %rd36, 2;                  // * 4 bytes f32
    add.u64 %rd36, %rd36, 4096;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd36, %shmem_base;
    @%p1 st.shared.f32 [%smem_addr], %f0;
    add.u32 %r1, %r1, 1;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra V2_LOOP_S_OVER_K_7;
    bar.sync 0;  // FENCE: all warps finished S writes
    // Phase 3: online softmax + P writeback
    mov.f32 %f0, 0fFF800000;                  // local_max = -inf
    // row_max chunk 0: lane sees k = lane + 32*0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;                 // k < block_kv?
    add.u64 %rd41, %rd41, %rd40;              // warp_base + k
    shl.b64 %rd41, %rd41, 2;                  // * 4 bytes
    add.u64 %rd41, %rd41, 4096;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];     // S[k] or -inf
    max.f32 %f0, %f0, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    sub.f32 %f0, %old_max, %new_max;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;          // exp(old-new), <=1
    mul.f32 %row_sum, %row_sum, %correction;
    mov.f32 %f2, 0f00000000;                  // partial_sum = 0
    // P writeback chunk 0
    cvt.u64.u32 %rd40, %warp_id;
    mul.lo.u64 %rd40, %rd40, 32;
    cvt.u64.u32 %rd41, %lane;
    setp.lt.u64 %p0, %rd41, 32;
    add.u64 %rd41, %rd41, %rd40;
    shl.b64 %rd41, %rd41, 2;
    add.u64 %rd41, %rd41, 4096;
    add.u64 %smem_addr, %rd41, %shmem_base;
    mov.f32 %f1, 0fFF800000;
    @%p0 ld.shared.f32 %f1, [%smem_addr];
    sub.f32 %f1, %f1, %new_max;
    mul.f32 %f1, %f1, %log2e;
    ex2.approx.f32 %f1, %f1;                  // P = exp(S-new_max)
    @!%p0 mov.f32 %f1, 0f00000000;
    @%p0 st.shared.f32 [%smem_addr], %f1;     // in-place P writeback
    add.f32 %f2, %f2, %f1;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 16, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 8, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 4, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 2, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f2, 1, 31, 0xFFFFFFFF;
    add.f32 %f2, %f2, %shfl_tmp;
    add.f32 %row_sum, %row_sum, %f2;
    bar.sync 0;  // FENCE: all warps done writing P in-place
    // V tile load: cooperative, reuses K region
    mul.lo.u64 %rd58, %batch_idx, %rd5;
    add.u64 %rd58, %rd58, %head_idx;
    mul.lo.u64 %rd58, %rd58, %rd6;
    add.u64 %rd58, %rd58, %k_start;
    mul.lo.u64 %rd58, %rd58, %rd7;
    shl.b64 %rd58, %rd58, 2;
    add.u64 %rd58, %rd2, %rd58;               // v_base global
    cvt.u64.u32 %rd59, %tid_x;
V2_LOOP_V_LOAD_7:
    shl.b64 %rd60, %rd59, 2;
    add.u64 %rd61, %rd58, %rd60;
    ld.global.f32 %f0, [%rd61];
    cvt.rn.f16.f32 %h0, %f0;
    shl.b64 %rd60, %rd59, 1;
    add.u64 %rd60, %rd60, 2048;
    add.u64 %smem_addr, %rd60, %shmem_base;
    st.shared.b16 [%smem_addr], %h0;
    add.u64 %rd59, %rd59, 128;
    setp.lt.u64 %p0, %rd59, 1024;
    @%p0 bra V2_LOOP_V_LOAD_7;
    bar.sync 0;  // FENCE: V tile in shmem
    // Phase 5: O_acc += P * V (q_tile_iter = 7)
    mul.f32 %f48, %f48, %correction;
    mov.u32 %r5, 0;                           // k = 0
    mov.u32 %r6, 32;                           // block_kv
V2_LOOP_PV_OVER_K_7:
    cvt.u64.u32 %rd42, %warp_id;
    mul.lo.u64 %rd42, %rd42, 32;              // warp_id * block_kv
    cvt.u64.u32 %rd43, %r5;
    add.u64 %rd42, %rd42, %rd43;              // + k
    shl.b64 %rd42, %rd42, 2;                  // * 4 bytes
    add.u64 %rd42, %rd42, 4096;                 // + sp_iter_offset
    add.u64 %smem_addr, %rd42, %shmem_base;
    ld.shared.f32 %f0, [%smem_addr];          // P[k] scalar
    cvt.u64.u32 %rd44, %r5;
    mul.lo.u64 %rd44, %rd44, 32;              // k * head_dim
    shl.b64 %rd44, %rd44, 1;                  // * 2 bytes f16
    add.u64 %rd44, %rd44, 2048;
    add.u64 %rd44, %rd44, %shmem_base;
    cvt.u64.u32 %rd45, %lane;
    shl.b64 %rd45, %rd45, 1;                  // * 2 bytes f16
    add.u64 %smem_addr, %rd44, %rd45;
    ld.shared.b16 %h0, [%smem_addr];
    cvt.f32.f16 %f1, %h0;                     // V[k, d]
    fma.rn.f32 %f48, %f0, %f1, %f48;          // O_acc[i] += P*V
    add.u32 %r5, %r5, 1;
    setp.lt.u32 %p0, %r5, %r6;
    @%p0 bra V2_LOOP_PV_OVER_K_7;
    add.u64 %k_start, %k_start, 32;
    setp.lt.u64 %p0, %k_start, %k_max;
    @%p0 bra V2_LOOP_KV_START_7;
    // Phase 6: finalize + output store (q_tile_iter = 7)
    rcp.approx.f32 %f0, %row_sum;
    mul.f32 %f48, %f48, %f0;
    add.u32 %r7, %warp_id, 28;             // q_row_local = warp_id + q_tile_iter*4
    cvt.u64.u32 %rd46, %r7;
    add.u64 %rd47, %q_start, %rd46;           // q_row_global
    mul.lo.u64 %rd48, %batch_idx, %rd5;       // batch*heads
    add.u64 %rd48, %rd48, %head_idx;          // + head
    mul.lo.u64 %rd48, %rd48, %rd6;            // * seq_len
    add.u64 %rd48, %rd48, %rd47;              // + q_row_global
    mul.lo.u64 %rd48, %rd48, %rd7;            // * head_dim
    shl.b64 %rd48, %rd48, 1;                  // * 2 bytes f16
    add.u64 %rd48, %rd3, %rd48;               // out_base_global
    cvt.rn.f16.f32 %h0, %f48;
    cvt.u64.u32 %rd49, %lane;
    shl.b64 %rd49, %rd49, 1;                  // * 2 bytes
    add.u64 %rd49, %rd48, %rd49;              // out_base + d*2
    st.global.b16 [%rd49], %h0;
    // LSE store (lane 0 only, null-guarded)
    setp.eq.u32 %p1, %lane, 0;
    setp.ne.u64 %p_has_lse, %logsumexp_base, 0;
    and.pred %p1, %p1, %p_has_lse;
    lg2.approx.f32 %log_sum, %row_sum;
    mov.f32 %f1, 0f3F317218;                  // ln(2)
    mul.f32 %log_sum, %log_sum, %f1;          // log_sum = ln(row_sum)
    add.f32 %lse, %row_max, %log_sum;
    mul.lo.u64 %rd50, %batch_idx, %rd5;
    add.u64 %rd50, %rd50, %head_idx;
    mul.lo.u64 %rd50, %rd50, %rd6;
    add.u64 %rd50, %rd50, %rd47;
    shl.b64 %rd50, %rd50, 2;
    add.u64 %rd50, %logsumexp_base, %rd50;
    @%p1 st.global.f32 [%rd50], %lse;
    // CSHA A5: fused_output=false, no emission
    ret;
}
␀
