---
source: crates/nsl-codegen/tests/pca_segment_mask_snapshot.rs
expression: "snapshot_with(SegmentResidency::Streamed)"
---
    // PCA Tier A: extend %p0 with cross-segment disjunction (spec §5.1)
    cvt.u32.u64    %r_q_SEGMASK, %rd35;            // q_global low-32
    shl.b32        %r_q_SEGMASK, %r_q_SEGMASK, 1;                 // q*sizeof(u16)
    // SegmentResidency::Streamed is out of scope for PCA Tier A
    trap;                                        // planner mis-routed q
    ld.shared.u16  %rs_q_SEGMASK, [%seg_base];    // unreachable
    cvt.u32.u64    %r_k_SEGMASK, %rd34;            // k_global low-32
    shl.b32        %r_k_SEGMASK, %r_k_SEGMASK, 1;                 // k*sizeof(u16)
    // SegmentResidency::Streamed is out of scope for PCA Tier A
    trap;                                        // planner mis-routed k
    ld.shared.u16  %rs_k_SEGMASK, [%seg_base];    // unreachable
    setp.ne.u16    %p_seg_SEGMASK, %rs_q_SEGMASK, %rs_k_SEGMASK;
    or.pred        %p0, %p0, %p_seg_SEGMASK;
