---
source: crates/nsl-codegen/tests/pca_tier_b_preamble_isolation.rs
expression: ptx
---
    // ----- PCA Tier B: range-table preamble (spec sec 3.1, v2) -----
    // num_q_tiles=64, num_kv_tiles=64, base=0xDEADBEEF
    .reg .u32  %r_tile_q_TILERANGE,  %r_tile_kv_TILERANGE;
    .reg .b32  %rs_min_TILERANGE,   %rs_max_TILERANGE;
    .reg .b32  %rs_peer_min_TILERANGE, %rs_peer_max_TILERANGE;
    .reg .u16  %rs_tmp_u16_TILERANGE;
    .reg .u32  %lane_id_TILERANGE;
    .reg .pred %p_done_TILERANGE,   %p_lane_zero_TILERANGE;
    .reg .u64  %addr_min_TILERANGE, %addr_max_TILERANGE;
    .reg .u64  %seg_smem_TILERANGE, %wide_tile_off_TILERANGE;
    .reg .u32  %seg_byte_off_TILERANGE;

    cvta.shared.u64 %seg_smem_TILERANGE, seg_smem;
    mov.u32 %lane_id_TILERANGE, %laneid;

    // --- q-phase: 64 tiles x 64 tokens, addr_min=0xDEADBEEF, addr_max=0xDEADBF6F ---
    mov.u32 %r_tile_q_TILERANGE, 0;
LOOP_Q_TILERANGE:
    mul.lo.u32 %seg_byte_off_TILERANGE, %r_tile_q_TILERANGE, 64;
    add.u32 %seg_byte_off_TILERANGE, %seg_byte_off_TILERANGE, %lane_id_TILERANGE;
    shl.b32 %seg_byte_off_TILERANGE, %seg_byte_off_TILERANGE, 1;
    cvt.u64.u32 %wide_tile_off_TILERANGE, %seg_byte_off_TILERANGE;
    add.u64 %wide_tile_off_TILERANGE, %seg_smem_TILERANGE, %wide_tile_off_TILERANGE;
    ld.shared.u16 %rs_tmp_u16_TILERANGE, [%wide_tile_off_TILERANGE];
    cvt.u32.u16 %rs_min_TILERANGE, %rs_tmp_u16_TILERANGE;
    mov.b32 %rs_max_TILERANGE, %rs_min_TILERANGE;
    // fold lane + 32 into lane-local min/max
    add.u64 %wide_tile_off_TILERANGE, %wide_tile_off_TILERANGE, 64;
    ld.shared.u16 %rs_tmp_u16_TILERANGE, [%wide_tile_off_TILERANGE];
    cvt.u32.u16 %rs_peer_min_TILERANGE, %rs_tmp_u16_TILERANGE;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_min_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 16, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 16, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 8, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 8, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 4, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 4, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 2, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 2, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 1, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 1, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shl.b32 %seg_byte_off_TILERANGE, %r_tile_q_TILERANGE, 1;
    cvt.u64.u32 %wide_tile_off_TILERANGE, %seg_byte_off_TILERANGE;
    cvta.shared.u64 %addr_min_TILERANGE, shmem;
    add.u64 %addr_min_TILERANGE, %addr_min_TILERANGE, 3735928559;
    add.u64 %addr_min_TILERANGE, %addr_min_TILERANGE, %wide_tile_off_TILERANGE;
    cvta.shared.u64 %addr_max_TILERANGE, shmem;
    add.u64 %addr_max_TILERANGE, %addr_max_TILERANGE, 3735928687;
    add.u64 %addr_max_TILERANGE, %addr_max_TILERANGE, %wide_tile_off_TILERANGE;
    setp.eq.u32 %p_lane_zero_TILERANGE, %lane_id_TILERANGE, 0;
    @%p_lane_zero_TILERANGE cvt.u16.u32 %rs_tmp_u16_TILERANGE, %rs_min_TILERANGE;
    @%p_lane_zero_TILERANGE st.shared.u16 [%addr_min_TILERANGE], %rs_tmp_u16_TILERANGE;
    @%p_lane_zero_TILERANGE cvt.u16.u32 %rs_tmp_u16_TILERANGE, %rs_max_TILERANGE;
    @%p_lane_zero_TILERANGE st.shared.u16 [%addr_max_TILERANGE], %rs_tmp_u16_TILERANGE;
    add.u32 %r_tile_q_TILERANGE, %r_tile_q_TILERANGE, 1;
    setp.lt.u32 %p_done_TILERANGE, %r_tile_q_TILERANGE, 64;
    @%p_done_TILERANGE bra LOOP_Q_TILERANGE;

    // --- kv-phase: 64 tiles x 64 tokens, addr_min=0xDEADBFEF, addr_max=0xDEADC06F ---
    mov.u32 %r_tile_kv_TILERANGE, 0;
LOOP_KV_TILERANGE:
    mul.lo.u32 %seg_byte_off_TILERANGE, %r_tile_kv_TILERANGE, 64;
    add.u32 %seg_byte_off_TILERANGE, %seg_byte_off_TILERANGE, %lane_id_TILERANGE;
    shl.b32 %seg_byte_off_TILERANGE, %seg_byte_off_TILERANGE, 1;
    cvt.u64.u32 %wide_tile_off_TILERANGE, %seg_byte_off_TILERANGE;
    add.u64 %wide_tile_off_TILERANGE, %seg_smem_TILERANGE, %wide_tile_off_TILERANGE;
    ld.shared.u16 %rs_tmp_u16_TILERANGE, [%wide_tile_off_TILERANGE];
    cvt.u32.u16 %rs_min_TILERANGE, %rs_tmp_u16_TILERANGE;
    mov.b32 %rs_max_TILERANGE, %rs_min_TILERANGE;
    // fold lane + 32 into lane-local min/max
    add.u64 %wide_tile_off_TILERANGE, %wide_tile_off_TILERANGE, 64;
    ld.shared.u16 %rs_tmp_u16_TILERANGE, [%wide_tile_off_TILERANGE];
    cvt.u32.u16 %rs_peer_min_TILERANGE, %rs_tmp_u16_TILERANGE;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_min_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 16, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 16, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 8, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 8, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 4, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 4, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 2, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 2, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shfl.sync.bfly.b32 %rs_peer_min_TILERANGE, %rs_min_TILERANGE, 1, 0x1F, 0xFFFFFFFF;
    shfl.sync.bfly.b32 %rs_peer_max_TILERANGE, %rs_max_TILERANGE, 1, 0x1F, 0xFFFFFFFF;
    min.u32 %rs_min_TILERANGE, %rs_min_TILERANGE, %rs_peer_min_TILERANGE;
    max.u32 %rs_max_TILERANGE, %rs_max_TILERANGE, %rs_peer_max_TILERANGE;
    shl.b32 %seg_byte_off_TILERANGE, %r_tile_kv_TILERANGE, 1;
    cvt.u64.u32 %wide_tile_off_TILERANGE, %seg_byte_off_TILERANGE;
    cvta.shared.u64 %addr_min_TILERANGE, shmem;
    add.u64 %addr_min_TILERANGE, %addr_min_TILERANGE, 3735928815;
    add.u64 %addr_min_TILERANGE, %addr_min_TILERANGE, %wide_tile_off_TILERANGE;
    cvta.shared.u64 %addr_max_TILERANGE, shmem;
    add.u64 %addr_max_TILERANGE, %addr_max_TILERANGE, 3735928943;
    add.u64 %addr_max_TILERANGE, %addr_max_TILERANGE, %wide_tile_off_TILERANGE;
    setp.eq.u32 %p_lane_zero_TILERANGE, %lane_id_TILERANGE, 0;
    @%p_lane_zero_TILERANGE cvt.u16.u32 %rs_tmp_u16_TILERANGE, %rs_min_TILERANGE;
    @%p_lane_zero_TILERANGE st.shared.u16 [%addr_min_TILERANGE], %rs_tmp_u16_TILERANGE;
    @%p_lane_zero_TILERANGE cvt.u16.u32 %rs_tmp_u16_TILERANGE, %rs_max_TILERANGE;
    @%p_lane_zero_TILERANGE st.shared.u16 [%addr_max_TILERANGE], %rs_tmp_u16_TILERANGE;
    add.u32 %r_tile_kv_TILERANGE, %r_tile_kv_TILERANGE, 1;
    setp.lt.u32 %p_done_TILERANGE, %r_tile_kv_TILERANGE, 64;
    @%p_done_TILERANGE bra LOOP_KV_TILERANGE;

    bar.sync 0;  // range tables visible to all warps before kv-tile loop reads
    // ----- end PCA Tier B range-table preamble -----
