    // ----- PCA Tier B: skip predicate (spec sec 3.2) -----
    {
    .reg .u16  %qmin_TB, %qmax_TB, %kvmin_TB, %kvmax_TB;
    .reg .pred %p_lt_TB, %p_gt_TB, %p_skip_TB;
    .reg .u32  %tile_byte_TB;
    .reg .u64  %addr_TB, %tile_off_wide_TB;

    shl.b32 %tile_byte_TB, %qt, 1;
    cvt.u64.u32 %tile_off_wide_TB, %tile_byte_TB;
    cvta.shared.u64 %addr_TB, shmem;
    add.u64 %addr_TB, %addr_TB, 3735928559;
    add.u64 %addr_TB, %addr_TB, %tile_off_wide_TB;
    ld.shared.u16 %qmin_TB, [%addr_TB];
    cvta.shared.u64 %addr_TB, shmem;
    add.u64 %addr_TB, %addr_TB, 3735928687;
    add.u64 %addr_TB, %addr_TB, %tile_off_wide_TB;
    ld.shared.u16 %qmax_TB, [%addr_TB];
    shl.b32 %tile_byte_TB, %kvt, 1;
    cvt.u64.u32 %tile_off_wide_TB, %tile_byte_TB;
    cvta.shared.u64 %addr_TB, shmem;
    add.u64 %addr_TB, %addr_TB, 3735928815;
    add.u64 %addr_TB, %addr_TB, %tile_off_wide_TB;
    ld.shared.u16 %kvmin_TB, [%addr_TB];
    cvta.shared.u64 %addr_TB, shmem;
    add.u64 %addr_TB, %addr_TB, 3735928943;
    add.u64 %addr_TB, %addr_TB, %tile_off_wide_TB;
    ld.shared.u16 %kvmax_TB, [%addr_TB];
    setp.lt.u16 %p_lt_TB, %qmax_TB, %kvmin_TB;
    setp.gt.u16 %p_gt_TB, %qmin_TB, %kvmax_TB;
    or.pred %p_skip_TB, %p_lt_TB, %p_gt_TB;
    @%p_skip_TB bra KV_TILE_SKIP;
    }
    // ----- end PCA Tier B skip predicate -----
