.visible .entry flash_attn_p1_r1_hs_g4_c1_t0_q64_kv64 (
    .param .u64 q_ptr,
    .param .u64 k_ptr,
    .param .u64 v_ptr,
    .param .u64 out_ptr,
    .param .f32 scale,
    .param .u64 batch,
    .param .u64 heads,
    .param .u64 seq_len,
    .param .u64 head_dim,
    .param .u64 block_table_ptr,
    .param .u64 k_pool_ptr,
    .param .u64 v_pool_ptr,
    .param .u64 block_size,
    .param .u64 cos_ptr,
    .param .u64 sin_ptr,
    .param .u64 seq_ids_ptr,
    .param .u64 seq_lens_ptr,
    .param .u64 dfs_enter_ptr,
    .param .u64 dfs_exit_ptr,
    .param .u64 num_tree_nodes
)
{
    .shared .align 16 .b8 shmem[32768];
    .reg .u32 %tid_x, %bid_x, %bid_y;
    .reg .u64 %rd<64>;
    .reg .f32 %f<128>;
    .reg .b16 %h<32>;
    .reg .pred %p<16>;
    .reg .u32 %r<32>;
    .reg .f32 %scale;
    .reg .f32 %log2e;
    mov.f32 %log2e, 0x3FB8AA3B;  // 1.4426950408 (log2(e))
    .reg .u64 %k_start, %k_max;
    .reg .f32 %row_max, %row_sum, %correction;
    .reg .f32 %new_max, %old_max;
    .reg .f32 %shfl_tmp;
    .reg .f32 %cos_val, %sin_val;
    .reg .f32 %q_a, %q_b, %q_rot_a, %q_rot_b;
    ld.param.u64 %rd0, [q_ptr];
    ld.param.u64 %rd1, [k_ptr];
    ld.param.u64 %rd2, [v_ptr];
    ld.param.u64 %rd3, [out_ptr];
    ld.param.f32 %scale, [scale];
    ld.param.u64 %rd4, [batch];
    ld.param.u64 %rd5, [heads];
    ld.param.u64 %rd6, [seq_len];
    ld.param.u64 %rd7, [head_dim];
    ld.param.u64 %rd8, [block_table_ptr];
    ld.param.u64 %rd9, [k_pool_ptr];
    ld.param.u64 %rd10, [v_pool_ptr];
    ld.param.u64 %rd11, [block_size];
    ld.param.u64 %rd12, [cos_ptr];
    ld.param.u64 %rd13, [sin_ptr];
    ld.param.u64 %rd14, [seq_ids_ptr];
    ld.param.u64 %rd15, [seq_lens_ptr];
    mov.u32 %tid_x, %tid.x;
    mov.u32 %bid_x, %ctaid.x;
    mov.u32 %bid_y, %ctaid.y;
    // q_start = blockIdx.x * block_q
    cvt.u64.u32 %rd16, %bid_x;
    mul.lo.u64 %rd16, %rd16, 64;  // %rd16 = q_start
    // batch_head routing computed from blockIdx.y
    cvt.u64.u32 %rd17, %bid_y;
    rem.u64 %rd18, %rd17, %rd5;  // head_idx = bid_y % heads
    div.u64 %rd19, %rd17, %rd5;  // batch_idx = bid_y / heads
    // GQA: kv_head = q_head / 4 (compile-time literal)
    div.u64 %rd20, %rd18, 4;  // kv_head = head_idx / gqa_group_size
    // Load Q tile into shared memory
    // Compute Q base address for this batch/head/q_start
    mul.lo.u64 %rd21, %rd19, %rd5;   // batch_idx * heads
    add.u64 %rd21, %rd21, %rd18;      // + head_idx
    mul.lo.u64 %rd21, %rd21, %rd6;    // * seq_len
    add.u64 %rd21, %rd21, %rd16;      // + q_start
    mul.lo.u64 %rd21, %rd21, %rd7;    // * head_dim
    shl.b64 %rd21, %rd21, 2;          // * 4 (sizeof f32)
    add.u64 %rd21, %rd0, %rd21;       // q_base = q_ptr + offset
    // Cooperative Q load: each thread loads 64 elements
    cvt.u64.u32 %rd22, %tid_x;        // elem_idx = tid_x
    mov.u64 %rd23, 8192;                // total Q elements
    // RoPE: load Q from global, rotate in registers, store to SRAM
    // cos/sin loaded from global memory into registers (NOT SRAM)
    // RoPE style: stride = head_dim/2 (half_split)
    // cos/sin base = cos_ptr + q_start * head_dim * 4
    mul.lo.u64 %rd24, %rd16, %rd7;  // q_start * head_dim
    shl.b64 %rd24, %rd24, 2;        // * 4 bytes
    add.u64 %rd25, %rd12, %rd24;    // cos_base
    add.u64 %rd26, %rd13, %rd24;    // sin_base
LOOP_Q_LOAD_ROPE:
    // Compute paired dimension index for RoPE rotation
    rem.u64 %rd27, %rd22, 128;          // d = elem_idx % head_dim
    div.u64 %rd28, %rd22, 128;          // row = elem_idx / head_dim
    // Paired offset: stride = 64
    shl.b64 %rd29, %rd22, 2;        // global byte offset
    add.u64 %rd30, %rd21, %rd29;    // q_addr = q_base + offset
    add.u64 %rd31, %rd30, 256;          // q_addr + stride_bytes
    ld.global.f32 %q_a, [%rd30];
    ld.global.f32 %q_b, [%rd31];
    // cos/sin for this row's position and dimension
    mul.lo.u64 %rd32, %rd28, %rd7;  // row * head_dim
    add.u64 %rd32, %rd32, %rd27;    // + d
    shl.b64 %rd32, %rd32, 2;        // * 4 bytes
    add.u64 %rd33, %rd25, %rd32;    // cos_addr
    add.u64 %rd34, %rd26, %rd32;    // sin_addr
    ld.global.f32 %cos_val, [%rd33];
    ld.global.f32 %sin_val, [%rd34];
    mul.f32 %q_rot_a, %q_a, %cos_val;
    mul.f32 %f0, %q_b, %sin_val;
    sub.f32 %q_rot_a, %q_rot_a, %f0;
    mul.f32 %q_rot_b, %q_a, %sin_val;
    mul.f32 %f0, %q_b, %cos_val;
    add.f32 %q_rot_b, %q_rot_b, %f0;
    shl.b64 %rd29, %rd22, 2;        // shmem byte offset
    st.shared.f32 [shmem + %rd29], %q_rot_a;
    add.u64 %rd35, %rd29, 256;          // offset_b in shmem
    st.shared.f32 [shmem + %rd35], %q_rot_b;
    add.u64 %rd22, %rd22, 128;      // elem_idx += blockDim.x
    setp.lt.u64 %p0, %rd22, %rd23;
    @%p0 bra LOOP_Q_LOAD_ROPE;
    bar.sync 0;
    // Q tile now in shmem[0 .. block_q * head_dim * 4]
    // Initialize accumulators
    // O_acc = 0, row_max = -inf, row_sum = 0
    mov.f32 %row_max, 0xFF800000;  // -inf as IEEE 754
    mov.f32 %row_sum, 0x00000000;  // 0.0
    // O_acc: 64 registers per thread (f64..f127)
    mov.f32 %f64, 0x00000000;
    mov.f32 %f65, 0x00000000;
    mov.f32 %f66, 0x00000000;
    mov.f32 %f67, 0x00000000;
    mov.f32 %f68, 0x00000000;
    mov.f32 %f69, 0x00000000;
    mov.f32 %f70, 0x00000000;
    mov.f32 %f71, 0x00000000;
    mov.f32 %f72, 0x00000000;
    mov.f32 %f73, 0x00000000;
    mov.f32 %f74, 0x00000000;
    mov.f32 %f75, 0x00000000;
    mov.f32 %f76, 0x00000000;
    mov.f32 %f77, 0x00000000;
    mov.f32 %f78, 0x00000000;
    mov.f32 %f79, 0x00000000;
    mov.f32 %f80, 0x00000000;
    mov.f32 %f81, 0x00000000;
    mov.f32 %f82, 0x00000000;
    mov.f32 %f83, 0x00000000;
    mov.f32 %f84, 0x00000000;
    mov.f32 %f85, 0x00000000;
    mov.f32 %f86, 0x00000000;
    mov.f32 %f87, 0x00000000;
    mov.f32 %f88, 0x00000000;
    mov.f32 %f89, 0x00000000;
    mov.f32 %f90, 0x00000000;
    mov.f32 %f91, 0x00000000;
    mov.f32 %f92, 0x00000000;
    mov.f32 %f93, 0x00000000;
    mov.f32 %f94, 0x00000000;
    mov.f32 %f95, 0x00000000;
    mov.f32 %f96, 0x00000000;
    mov.f32 %f97, 0x00000000;
    mov.f32 %f98, 0x00000000;
    mov.f32 %f99, 0x00000000;
    mov.f32 %f100, 0x00000000;
    mov.f32 %f101, 0x00000000;
    mov.f32 %f102, 0x00000000;
    mov.f32 %f103, 0x00000000;
    mov.f32 %f104, 0x00000000;
    mov.f32 %f105, 0x00000000;
    mov.f32 %f106, 0x00000000;
    mov.f32 %f107, 0x00000000;
    mov.f32 %f108, 0x00000000;
    mov.f32 %f109, 0x00000000;
    mov.f32 %f110, 0x00000000;
    mov.f32 %f111, 0x00000000;
    mov.f32 %f112, 0x00000000;
    mov.f32 %f113, 0x00000000;
    mov.f32 %f114, 0x00000000;
    mov.f32 %f115, 0x00000000;
    mov.f32 %f116, 0x00000000;
    mov.f32 %f117, 0x00000000;
    mov.f32 %f118, 0x00000000;
    mov.f32 %f119, 0x00000000;
    mov.f32 %f120, 0x00000000;
    mov.f32 %f121, 0x00000000;
    mov.f32 %f122, 0x00000000;
    mov.f32 %f123, 0x00000000;
    mov.f32 %f124, 0x00000000;
    mov.f32 %f125, 0x00000000;
    mov.f32 %f126, 0x00000000;
    mov.f32 %f127, 0x00000000;
    // Causal: k_max = min(q_start + block_q, seq_len)
    add.u64 %k_max, %rd16, 64;  // q_start + block_q
    min.u64 %k_max, %k_max, %rd6;  // min(..., seq_len)
    mov.u64 %k_start, 0;
    // === Main K/V tile loop ===
    // Causal: k_max = min(seq_len, q_start + block_q)
    // Zero-divergence — loop naturally terminates at diagonal
    setp.ge.u64 %p0, %k_start, %k_max;
    @%p0 bra LOOP_KV_END;
LOOP_KV_START:
    // Phase 1: Load K tile into SRAM
    // shmem_K base = shmem + 32768 (after Q tile)
    // Paged: block table indirection per physical block
    // One page table lookup per block_size tokens
    div.u64 %rd36, %k_start, %rd11;  // logical_block = k_start / block_size
    // block_table[batch_idx * heads + head_idx_kv, logical_block]
    mul.lo.u64 %rd37, %rd19, %rd5;  // batch_idx * heads
    add.u64 %rd37, %rd37, %rd20;    // + kv_head
    // TODO: compute block_table stride from max_blocks
    shl.b64 %rd38, %rd36, 2;           // * 4 (u32 block indices)
    add.u64 %rd38, %rd8, %rd38;        // block_table_ptr + offset
    ld.global.u32 %r0, [%rd38];        // physical_block
    cvt.u64.u32 %rd39, %r0;            // physical_block as u64
    mul.lo.u64 %rd40, %rd39, %rd11;    // phys_block * block_size
    mul.lo.u64 %rd40, %rd40, %rd7;     // * head_dim
    shl.b64 %rd40, %rd40, 2;           // * 4 bytes
    add.u64 %rd40, %rd9, %rd40;        // k_base = k_pool_ptr + offset
    // Cooperative K load: 8192 total elements, 64 per thread
    cvt.u64.u32 %rd41, %tid_x;             // elem_idx = tid_x
    mov.u64 %rd42, 8192;                    // total K elements
LOOP_K_LOAD:
    shl.b64 %rd43, %rd41, 2;               // byte offset = elem_idx * 4
    add.u64 %rd44, %rd40, %rd43;           // global addr
    ld.global.f32 %f0, [%rd44];
    add.u64 %rd45, %rd43, 32768;             // shmem_K byte offset
    st.shared.f32 [shmem + %rd45], %f0;
    add.u64 %rd41, %rd41, 128;             // elem_idx += blockDim.x
    setp.lt.u64 %p0, %rd41, %rd42;
    @%p0 bra LOOP_K_LOAD;
    bar.sync 0;  // FENCE 1: K tile fully in SRAM
    // Phase 2: S = Q_tile @ K_tile^T (registers)
    // Each thread computes 32 S values
    mov.u32 %r1, 0;                        // s_iter = 0
    mov.u32 %r2, 32;                      // num_s_per_thread
LOOP_S_OUTER:
    // linear_idx = tid_x + s_iter * 128
    mul.lo.u32 %r3, %r1, 128;
    add.u32 %r3, %r3, %tid_x;
    div.u32 %r4, %r3, 64;                 // q_row = linear_idx / block_kv
    rem.u32 %r5, %r3, 64;                 // k_col = linear_idx % block_kv
    mov.f32 %f0, 0x00000000;               // S accumulator = 0
    mov.u32 %r6, 0;                        // d = 0
    mov.u32 %r7, 128;                      // head_dim
LOOP_HD:
    cvt.u64.u32 %rd43, %r4;               // q_row as u64
    mul.lo.u64 %rd43, %rd43, 128;          // q_row * head_dim
    cvt.u64.u32 %rd44, %r6;               // d as u64
    add.u64 %rd43, %rd43, %rd44;           // q_row * head_dim + d
    shl.b64 %rd43, %rd43, 2;              // * 4 bytes
    ld.shared.f32 %f1, [shmem + %rd43];   // Q[q_row][d]
    cvt.u64.u32 %rd44, %r5;               // k_col as u64
    mul.lo.u64 %rd44, %rd44, 128;          // k_col * head_dim
    cvt.u64.u32 %rd45, %r6;               // d as u64
    add.u64 %rd44, %rd44, %rd45;           // k_col * head_dim + d
    shl.b64 %rd44, %rd44, 2;              // * 4 bytes
    add.u64 %rd44, %rd44, 32768;             // + shmem_K base offset
    ld.shared.f32 %f2, [shmem + %rd44];   // K[k_col][d]
    fma.rn.f32 %f0, %f1, %f2, %f0;       // S += Q[d] * K[d]
    add.u32 %r6, %r6, 1;                  // d++
    setp.lt.u32 %p0, %r6, %r7;
    @%p0 bra LOOP_HD;
    // S[i][j] *= scale  (mul.f32)
    mul.f32 %f0, %f0, %scale;
    // Partial causal mask on diagonal tile: S[i][j] = -inf where k_start+j > q_start+i
    cvt.u64.u32 %rd43, %r5;           // k_col as u64
    add.u64 %rd43, %k_start, %rd43;   // k_abs = k_start + k_col
    cvt.u64.u32 %rd44, %r4;           // q_row as u64
    add.u64 %rd44, %rd16, %rd44;      // q_abs = q_start + q_row
    setp.gt.u64 %p1, %rd43, %rd44;    // k_abs > q_abs?
    @%p1 mov.f32 %f0, 0xFF800000;     // -inf for masked positions
    // Store S value for this thread's s_iter
    setp.eq.u32 %p2, %r1, 0;
    @%p2 mov.f32 %f3, %f0;
    setp.eq.u32 %p2, %r1, 1;
    @%p2 mov.f32 %f4, %f0;
    setp.eq.u32 %p2, %r1, 2;
    @%p2 mov.f32 %f5, %f0;
    setp.eq.u32 %p2, %r1, 3;
    @%p2 mov.f32 %f6, %f0;
    setp.eq.u32 %p2, %r1, 4;
    @%p2 mov.f32 %f7, %f0;
    setp.eq.u32 %p2, %r1, 5;
    @%p2 mov.f32 %f8, %f0;
    setp.eq.u32 %p2, %r1, 6;
    @%p2 mov.f32 %f9, %f0;
    setp.eq.u32 %p2, %r1, 7;
    @%p2 mov.f32 %f10, %f0;
    setp.eq.u32 %p2, %r1, 8;
    @%p2 mov.f32 %f11, %f0;
    setp.eq.u32 %p2, %r1, 9;
    @%p2 mov.f32 %f12, %f0;
    setp.eq.u32 %p2, %r1, 10;
    @%p2 mov.f32 %f13, %f0;
    setp.eq.u32 %p2, %r1, 11;
    @%p2 mov.f32 %f14, %f0;
    setp.eq.u32 %p2, %r1, 12;
    @%p2 mov.f32 %f15, %f0;
    setp.eq.u32 %p2, %r1, 13;
    @%p2 mov.f32 %f16, %f0;
    setp.eq.u32 %p2, %r1, 14;
    @%p2 mov.f32 %f17, %f0;
    setp.eq.u32 %p2, %r1, 15;
    @%p2 mov.f32 %f18, %f0;
    setp.eq.u32 %p2, %r1, 16;
    @%p2 mov.f32 %f19, %f0;
    setp.eq.u32 %p2, %r1, 17;
    @%p2 mov.f32 %f20, %f0;
    setp.eq.u32 %p2, %r1, 18;
    @%p2 mov.f32 %f21, %f0;
    setp.eq.u32 %p2, %r1, 19;
    @%p2 mov.f32 %f22, %f0;
    setp.eq.u32 %p2, %r1, 20;
    @%p2 mov.f32 %f23, %f0;
    setp.eq.u32 %p2, %r1, 21;
    @%p2 mov.f32 %f24, %f0;
    setp.eq.u32 %p2, %r1, 22;
    @%p2 mov.f32 %f25, %f0;
    setp.eq.u32 %p2, %r1, 23;
    @%p2 mov.f32 %f26, %f0;
    setp.eq.u32 %p2, %r1, 24;
    @%p2 mov.f32 %f27, %f0;
    setp.eq.u32 %p2, %r1, 25;
    @%p2 mov.f32 %f28, %f0;
    setp.eq.u32 %p2, %r1, 26;
    @%p2 mov.f32 %f29, %f0;
    setp.eq.u32 %p2, %r1, 27;
    @%p2 mov.f32 %f30, %f0;
    setp.eq.u32 %p2, %r1, 28;
    @%p2 mov.f32 %f31, %f0;
    setp.eq.u32 %p2, %r1, 29;
    @%p2 mov.f32 %f32, %f0;
    setp.eq.u32 %p2, %r1, 30;
    @%p2 mov.f32 %f33, %f0;
    setp.eq.u32 %p2, %r1, 31;
    @%p2 mov.f32 %f34, %f0;
    add.u32 %r1, %r1, 1;                  // s_iter++
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra LOOP_S_OUTER;
    bar.sync 0;  // FENCE 2: all warps done reading K before SRAM overwrite
    // Phase 3: Online softmax — S→P in-place in registers
    // Local max from this thread's S values
    mov.f32 %f0, 0xFF800000;               // f_local_max = -inf
    max.f32 %f0, %f0, %f3;              // max with S[0]
    max.f32 %f0, %f0, %f4;              // max with S[1]
    max.f32 %f0, %f0, %f5;              // max with S[2]
    max.f32 %f0, %f0, %f6;              // max with S[3]
    max.f32 %f0, %f0, %f7;              // max with S[4]
    max.f32 %f0, %f0, %f8;              // max with S[5]
    max.f32 %f0, %f0, %f9;              // max with S[6]
    max.f32 %f0, %f0, %f10;              // max with S[7]
    max.f32 %f0, %f0, %f11;              // max with S[8]
    max.f32 %f0, %f0, %f12;              // max with S[9]
    max.f32 %f0, %f0, %f13;              // max with S[10]
    max.f32 %f0, %f0, %f14;              // max with S[11]
    max.f32 %f0, %f0, %f15;              // max with S[12]
    max.f32 %f0, %f0, %f16;              // max with S[13]
    max.f32 %f0, %f0, %f17;              // max with S[14]
    max.f32 %f0, %f0, %f18;              // max with S[15]
    max.f32 %f0, %f0, %f19;              // max with S[16]
    max.f32 %f0, %f0, %f20;              // max with S[17]
    max.f32 %f0, %f0, %f21;              // max with S[18]
    max.f32 %f0, %f0, %f22;              // max with S[19]
    max.f32 %f0, %f0, %f23;              // max with S[20]
    max.f32 %f0, %f0, %f24;              // max with S[21]
    max.f32 %f0, %f0, %f25;              // max with S[22]
    max.f32 %f0, %f0, %f26;              // max with S[23]
    max.f32 %f0, %f0, %f27;              // max with S[24]
    max.f32 %f0, %f0, %f28;              // max with S[25]
    max.f32 %f0, %f0, %f29;              // max with S[26]
    max.f32 %f0, %f0, %f30;              // max with S[27]
    max.f32 %f0, %f0, %f31;              // max with S[28]
    max.f32 %f0, %f0, %f32;              // max with S[29]
    max.f32 %f0, %f0, %f33;              // max with S[30]
    max.f32 %f0, %f0, %f34;              // max with S[31]
    // Warp-level reductions via shfl.sync.bfly for row_max, row_sum
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 16, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 8, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 4, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 2, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    shfl.sync.bfly.b32 %shfl_tmp, %f0, 1, 31, 0xFFFFFFFF;
    max.f32 %f0, %f0, %shfl_tmp;
    // new_max = max(row_max, warp_reduce_max(row_max_of_S))
    mov.f32 %old_max, %row_max;
    max.f32 %new_max, %row_max, %f0;
    mov.f32 %row_max, %new_max;
    // correction = exp(old_max - new_max)  // <= 1.0, no overflow
    sub.f32 %f0, %old_max, %new_max;
    mul.f32 %f0, %f0, %log2e;
    ex2.approx.f32 %correction, %f0;
    // row_sum = row_sum * correction + warp_reduce_sum(exp(S - new_max))
    mul.f32 %row_sum, %row_sum, %correction;
    // O_acc *= correction
    mul.f32 %f64, %f64, %correction;
    mul.f32 %f65, %f65, %correction;
    mul.f32 %f66, %f66, %correction;
    mul.f32 %f67, %f67, %correction;
