    xor.b32 %r_slot_curr, %r_slot_curr, 1;
    // === Tier B.1 native output scatter (B1.6 deferral #9 + N3) ===
    .reg .f32 %fin_norm;
    .reg .u32 %fin_lo_row, %fin_lo_col_base;
    .reg .u32 %fin_row_in_tile, %fin_col_in_tile;
    .reg .u32 %fin_q_row_u32, %fin_d_col_u32;
    .reg .u32 %fin_laneid, %fin_lane_mod4;
    .reg .u32 %fin_global_t, %fin_m_tile, %fin_n_tile;
    .reg .u32 %fin_m_tile_x16, %fin_n_tile_x8;
    .reg .u64 %fin_q_row, %fin_d_col, %fin_idx, %fin_idx2;
    .reg .u64 %fin_addr;
    .reg .b16 %fin_h;
    .reg .pred %fin_lane0_pred;
    mov.u32 %fin_laneid, %tid.x;
    and.b32 %fin_laneid, %fin_laneid, 31;
    shr.u32 %fin_lo_row, %fin_laneid, 2;       // l/4 = D-fragment row within lo half
    and.b32 %fin_lo_col_base, %fin_laneid, 3;  // l%4
    shl.b32 %fin_lo_col_base, %fin_lo_col_base, 1; // (l%4)*2 = D-fragment col base
    and.b32 %fin_lane_mod4, %fin_laneid, 3;    // for LSE lane-0-of-quad gate
    // ---- Output slot local_t=0 (global_t = warp_id + 0*8 at runtime; N3) ----
    mov.u32 %fin_global_t, %warp_id;
    shr.u32 %fin_m_tile, %fin_global_t, 2;
    and.b32 %fin_n_tile, %fin_global_t, 3;
    shl.b32 %fin_m_tile_x16, %fin_m_tile, 4;   // m_tile * 16
    shl.b32 %fin_n_tile_x8, %fin_n_tile, 3;    // n_tile * 8
    div.approx.f32 %fin_norm, %o_acc_0_0, %s_sum_0_lo;
    add.u32 %fin_row_in_tile, %fin_lo_row, 0;
    add.u32 %fin_col_in_tile, %fin_lo_col_base, 0;
    add.u32 %fin_q_row_u32, %fin_row_in_tile, %fin_m_tile_x16;
    add.u32 %fin_d_col_u32, %fin_col_in_tile, %fin_n_tile_x8;
    cvt.u64.u32 %fin_q_row, %fin_q_row_u32;
    cvt.u64.u32 %fin_d_col, %fin_d_col_u32;
    add.u64 %fin_q_row, %fin_q_row, %q_start;
    mul.lo.u64 %fin_idx, %batch_idx, %rd5;
    add.u64 %fin_idx, %fin_idx, %head_idx;
    mul.lo.u64 %fin_idx, %fin_idx, %rd6;
    add.u64 %fin_idx, %fin_idx, %fin_q_row;
    mul.lo.u64 %fin_idx, %fin_idx, %rd7;
    add.u64 %fin_idx, %fin_idx, %fin_d_col;
