    // === Tier B.1 KV projection: bkv=32 hd=32 d_model=2048 chunk=128 n_chunks=16 kv_iter=0 slot=1 tiles_per_warp_kv=1 ===
    .reg .u64 %tb1_kv_x_ptr, %tb1_kv_wk_ptr, %tb1_kv_wv_ptr;
    .reg .pred %tb1_kv_xnull, %tb1_kv_wknull, %tb1_kv_wvnull;
    .reg .u64 %tb1_kv_smem_wk, %tb1_kv_smem_wv, %tb1_kv_smem_x;
    .reg .u32 %tb1_kv_smem_wk_u32, %tb1_kv_smem_wv_u32, %tb1_kv_smem_x_u32;
    .reg .u32 %tb1_kv_cp_tid_off;
    .reg .u32 %tb1_kv_cp_smem_addr, %tb1_kv_cp_hbm_off;
    .reg .u64 %tb1_kv_cp_hbm_addr;
    mov.u32 %tb1_kv_cp_tid_off, %tid.x;
    shl.b32 %tb1_kv_cp_tid_off, %tb1_kv_cp_tid_off, 4; // tid * 16 (B1.6 deferral #3)
    .reg .u64 %tb1_kv_smem_k, %tb1_kv_smem_v;
    .reg .u64 %tb1_kv_scatter_addr;
    .reg .b16 %tb1_kv_h0;
    // Null-guard csha_x_ptr; on null, skip KV projection.
    ld.param.u64 %tb1_kv_x_ptr, [csha_x_ptr];
    setp.eq.u64 %tb1_kv_xnull, %tb1_kv_x_ptr, 0;
    @%tb1_kv_xnull bra V2_TIER_B1_KV_PROJ_SKIP_1;
    // Null-guard csha_wk_ptr; on null, skip KV projection.
    ld.param.u64 %tb1_kv_wk_ptr, [csha_wk_ptr];
    setp.eq.u64 %tb1_kv_wknull, %tb1_kv_wk_ptr, 0;
