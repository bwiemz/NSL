    add.u32 %mma_addr, %mma_addr, 16;  // + k byte offset
    ld.shared.b32 %tb1_kv_bv_0_0_1, [%mma_addr];
    setp.eq.u32 %wo_pred, %warp_id, 0; // K-proj tile t=0 ownership
    @%wo_pred mma.sync.aligned.m16n8k16.row.col.f32.f16.f16.f32
        {%k_acc_0_0, %k_acc_0_1, %k_acc_0_2, %k_acc_0_3},
        {%tb1_kv_a_0_0_0, %tb1_kv_a_0_0_1, %tb1_kv_a_0_0_2, %tb1_kv_a_0_0_3},
