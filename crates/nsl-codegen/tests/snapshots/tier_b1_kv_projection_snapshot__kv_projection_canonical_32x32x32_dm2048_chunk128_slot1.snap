    cvt.u32.u64 %tb1_kv_smem_x_u32, %tb1_kv_smem_x;
    add.u64 %tb1_kv_smem_k, %shmem_base, 4096; // K output tile (slot=1)
    add.u64 %tb1_kv_smem_v, %shmem_base, 8192; // V output tile (slot=1)
    // -- KV-proj chunk 1/16 (d_model offset 0 .. 128) --
    // cp.async Wk[0:128] -> SMEM[wk_chunk_off slot 0]
    add.u32 %tb1_kv_cp_smem_addr, %tb1_kv_smem_wk_u32, %tb1_kv_cp_tid_off;
    cvt.u32.u64 %tb1_kv_cp_hbm_off, %tb1_kv_wk_ptr;
    add.u32 %tb1_kv_cp_hbm_off, %tb1_kv_cp_hbm_off, 0;
    add.u32 %tb1_kv_cp_hbm_off, %tb1_kv_cp_hbm_off, %tb1_kv_cp_tid_off;
    cvt.u64.u32 %tb1_kv_cp_hbm_addr, %tb1_kv_cp_hbm_off;
    cp.async.cg.shared.global [%tb1_kv_cp_smem_addr], [%tb1_kv_cp_hbm_addr], 16;
    // cp.async Wv[0:128] -> SMEM[wv_chunk_off slot 1]
