# v1_mlp.nsl — v1 MLP NSL source for M57 FPGA target.
#
# Architecture: 784 → 128 → 10, two-layer INT8 MLP forward pass.
#
# This file matches the shape recognized by `nsl_codegen::kernel_lower_fpga::lower`
# (M57.1 §3.3): a single `model TinyMlp:` block with `W<i>` / `b<i>` field
# decls and exactly one `fn forward(self, x)` method whose body emits
# `relu(matmul(<prev>, self.W<i>) + self.b<i>)` per layer (N-1 let-bindings
# + 1 return).
#
# Field dtypes / shapes match the companion fixture's manifest
# (`mlp_int8_weights_v1.toml`):
#   W1: i8  [784, 128]   weights, layer 1
#   b1: i32 [128]        bias, layer 1
#   W2: i8  [128, 10]    weights, layer 2
#   b2: i64 [10]         bias, layer 2
#
# Stimulus shape (x): [1, 784] i8 — single-row "batched" form so the v1
# MLP path stays close to NSL's two-rank matmul convention.

model TinyMlp:
    W1: Tensor<[784, 128], i8>
    b1: Tensor<[128], i32>
    W2: Tensor<[128, 10], i8>
    b2: Tensor<[10], i64>

    fn forward(self, x: Tensor<[1, 784], i8>) -> Tensor<[1, 10], i64>:
        let h = relu(matmul(x, self.W1) + self.b1)
        return relu(matmul(h, self.W2) + self.b2)
