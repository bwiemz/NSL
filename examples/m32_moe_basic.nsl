# M32: Basic MoE decorator and moe_dispatch intrinsic test
# moe_dispatch is currently a pass-through returning input tensor

model MoEModel:
    @moe(num_experts=2, top_k=1, capacity_factor=1.5)
    experts: int = 2

    fn forward(self, x: Tensor) -> Tensor:
        let logits = ones([2, 2])
        let out = moe_dispatch(x, logits, self.experts)
        return out

let m = MoEModel()
let x = ones([2, 4])
let y = m.forward(x)
print(y)
