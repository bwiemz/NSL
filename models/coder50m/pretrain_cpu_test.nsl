# CPU pretraining test — verify train block works with full NSLCoder model
from model import NSLCoder
from nsl.nn.losses import cross_entropy

print("Initializing model (CPU)...")
let m = NSLCoder()
print("Model created")

let tokens = load_mmap("C:/Users/bwiem/ai testing/codeforge/data/pretokenized/150m/tokens.bin", 3)
let loader = DataLoader(tokens, batch_size=1, seq_len=64, shuffle=false, drop_last=true)

print("Starting CPU train block test...")
train(model=m, epochs=1):
    optimizer: AdamW(lr=0.0003)
    step(batch):
        let logits = m.forward_train(batch.input_ids, true)
        let ls = logits.shape
        let flat_logits = logits.reshape([ls[0] * ls[1], ls[2]])
        let flat_labels = batch.labels.reshape([ls[0] * ls[1]])
        let loss = cross_entropy(flat_logits, flat_labels)
    callbacks:
        on_step(step, loss):
            print(step)
            print(loss)
            if step >= 2:
                print("CPU test passed - loss computed with backward!")

print("Done!")
