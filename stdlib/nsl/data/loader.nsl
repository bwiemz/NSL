# NeuralScript Data Pipeline Module (nsl.data)
#
# Built-in intrinsics (available without importing this module):
#
#   load_jsonl(path, field) -> List[str]
#       Load a JSONL file, extract a named field from each line.
#       Small-data utility for eval sets and prompt lists.
#
#   load_csv(path, col_idx, has_header=1) -> List[str]
#       Load a CSV file, extract a column by index.
#       Small-data utility for eval sets.
#
#   load_mmap(path, dtype) -> Tensor
#       Memory-map a binary file as a flat 1D tensor.
#       dtype: 0=f64, 1=f32, 2=i32, 3=u16
#       u16 (dtype=3) is the primary pathway for pre-tokenized LLM datasets.
#       Zero-copy: data points directly into the mapped file.
#
#   DataLoader(data, labels=none, batch_size=32, seq_len=128, shuffle=false,
#              num_workers=1, prefetch=2, packing=false,
#              pack_separator=0, drop_last=true) -> DataLoader
#       Create a multi-threaded data loader with batching.
#       Iterate with: for batch in loader:
#       Each batch is a Dict with keys:
#           "input_ids"      [B, S] token ids
#           "labels"         [B, S] labels
#       If `labels` is provided, those labels are used verbatim.
#       `labels` must be a tensor with the same number of elements as `data`.
#       Omit it or pass `labels=none` to use shifted labels instead.
#       `packing=true` is currently unsupported in the stdlib DataLoader path
#       because packed attention masks are not yet propagated into model attention.
#       `drop_last=false` is currently unsupported because partial tail batches
#       are not implemented.
#       `pin_memory=true` is currently unsupported.
#       Otherwise labels are generated by shifting `input_ids` by one token and
#       marking only the final position in each sequence as `-100`.
#       Note: causal attention mask is generated inside the model's GQA layer
#       via causal_mask(seq_len), not in the DataLoader.

fn data_version() -> int:
    return 1
