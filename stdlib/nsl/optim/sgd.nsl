fn sgd_step(param: Tensor, gradient: Tensor, velocity: Tensor, lr: float, momentum: float, dampening: float, weight_decay: float, nesterov: bool):
    copy_data(velocity, momentum * velocity + (1.0 - dampening) * gradient)
    let update = velocity
    if nesterov:
        update = gradient + momentum * velocity
    if weight_decay > 0.0:
        copy_data(param, param * (1.0 - lr * weight_decay) - lr * update)
    else:
        copy_data(param, param - lr * update)
