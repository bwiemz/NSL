@quantize(dtype="awq4", group_size=128)
model TinyMLP:
    up_proj: Tensor = zeros([128, 64])
    down_proj: Tensor = zeros([64, 128])

    fn forward(self, x: Tensor) -> Tensor:
        let h = relu(x @ self.up_proj)
        return h @ self.down_proj

let m = TinyMLP()
let x = zeros([1, 64])
let y = zeros([1, 64])

train(model = m, epochs = 1):
    optimizer: SGD(lr = 0.01)
    step(batch):
        let pred = m.forward(x)
        let diff = pred - y
        let loss = mean(diff * diff)
