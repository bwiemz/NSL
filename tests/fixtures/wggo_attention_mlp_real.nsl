# Merge-gate fixture for WGGO Phase 2 Tasks 27+28.
# Single attention block (Q/K/V/O projections + softmax) with @wggo_target on
# the forward pass. Small dimensions (dim=32, num_heads=4, head_dim=8) for fast
# tests. Calibration data: [8, 4, 32] f32 in wggo_calib_data.safetensors.
#
# The merge-gate test (`wggo_backward_pipeline.rs`) calls
# `real_subprocess_entry` directly — under #134's (c-i) convergence,
# this is the canonical calibration entry point that
# `compile_and_calibrate` itself invokes (pre-`compile_main`, see
# lib.rs's compile_and_calibrate wrapper). The test exercises the
# same path that production calibration takes.
#
# As a result this fixture has no `train` block — calibration fires
# from `real_subprocess_entry` based on registered hooks, not from
# `compile_train_block` (whose calibration block was deleted in #134).
# The `@wggo_target` decorator on the forward method is the only
# declaration needed.
from nsl.nn.losses import mse_loss

@quantize(dtype="awq4")
model AttentionMLP(dim: int, num_heads: int):
    head_dim: int = dim // num_heads
    q_proj: Tensor<[dim, dim], f32> = zeros([dim, dim])
    k_proj: Tensor<[dim, dim], f32> = zeros([dim, dim])
    v_proj: Tensor<[dim, dim], f32> = zeros([dim, dim])
    o_proj: Tensor<[dim, dim], f32> = zeros([dim, dim])

    @wggo_target(w_q=self.q_proj, w_k=self.k_proj, w_v=self.v_proj, w_o=self.o_proj, head_dim=self.head_dim)
    fn forward(self, x: Tensor) -> Tensor:
        let q = x @ self.q_proj
        let k = x @ self.k_proj
        let v = x @ self.v_proj
        let scores = q @ k.transpose(1, 2)
        let attn = softmax(scores, 2)
        let out = attn @ v
        return out @ self.o_proj

fn main():
    let m = AttentionMLP(dim=32, num_heads=4)
    let x = zeros([8, 4, 32])
    let y = m.forward(x)
