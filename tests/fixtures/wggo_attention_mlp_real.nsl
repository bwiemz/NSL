# Merge-gate fixture for WGGO Phase 2 Tasks 27+28.
# Single attention block (Q/K/V/O projections + softmax) with @wggo_target on
# the forward pass. Small dimensions (dim=32, num_heads=4, head_dim=8) for fast
# tests. Calibration data: [8, 4, 32] f32 in wggo_calib_data.safetensors.
#
# Choice: option B — the Task 9 placeholder (wggo_attention_mlp.nsl / TinyAttn)
# is preserved unchanged; this file is the full merge-gate fixture.
from nsl.nn.losses import mse_loss

@quantize(dtype="awq4")
model AttentionMLP(dim: int, num_heads: int):
    head_dim: int = dim // num_heads
    q_proj: Tensor = zeros([dim, dim])
    k_proj: Tensor = zeros([dim, dim])
    v_proj: Tensor = zeros([dim, dim])
    o_proj: Tensor = zeros([dim, dim])

    @wggo_target(w_q=self.q_proj, w_k=self.k_proj, w_v=self.v_proj, w_o=self.o_proj, head_dim=self.head_dim)
    fn forward(self, x: Tensor) -> Tensor:
        let q = x @ self.q_proj
        let k = x @ self.k_proj
        let v = x @ self.v_proj
        let scores = q @ k.transpose(1, 2)
        let attn = softmax(scores, 2)
        let out = attn @ v
        return out @ self.o_proj

fn main():
    let m = AttentionMLP(dim=32, num_heads=4)
    let x = zeros([8, 4, 32])
    let y = m.forward(x)
