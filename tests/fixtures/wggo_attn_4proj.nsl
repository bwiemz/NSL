# Fixture for Task 16: model with four weight projections used in the forward pass.
# Uses the pipe operator (|>) so AWQ pre-scan discovers all four projections.
# The WengertExtractor sees q_proj, k_proj, v_proj, o_proj as Param VarIds whose
# adjoints map to four grad-arena slots.
#
# Shape convention: x is [batch, seq, 16].  All projections are [16, 16] squares
# so `x |> proj` = `x @ proj` succeeds for all.

@quantize(dtype="awq4")
model TinyAttn4:
    q_proj: Tensor = zeros([16, 16])
    k_proj: Tensor = zeros([16, 16])
    v_proj: Tensor = zeros([16, 16])
    o_proj: Tensor = zeros([16, 16])

    @wggo_target(w_q=self.q_proj, w_k=self.k_proj, w_v=self.v_proj, w_o=self.o_proj, head_dim=4)
    fn forward(self, x: Tensor) -> Tensor:
        return x |> q_proj |> k_proj |> v_proj |> o_proj

fn main():
    let m = TinyAttn4()
