# M15 Comprehensive Test Suite
# Tests: activations, tensor ops, NN layers, dropout, tokenizer, assertions

# ============================================================
# Activation Functions
# ============================================================

@test
fn test_relu_positive():
    let x = full([3], 2.0)
    let y = relu(x)
    assert_close(y, full([3], 2.0), 0.001, 0.001)

@test
fn test_relu_negative():
    let x = full([3], -1.0)
    let y = relu(x)
    assert_close(y, zeros([3]), 0.001, 0.001)

@test
fn test_relu_zero():
    let x = zeros([4])
    let y = relu(x)
    assert_close(y, zeros([4]), 0.001, 0.001)

@test
fn test_gelu():
    let x = ones([3])
    let y = gelu(x)
    # GELU(1.0) ≈ 0.8412
    let expected = full([3], 0.8412)
    assert_close(y, expected, 0.01, 0.01)

@test
fn test_gelu_zero():
    let x = zeros([3])
    let y = gelu(x)
    # GELU(0.0) = 0.0
    assert_close(y, zeros([3]), 0.001, 0.001)

@test
fn test_silu():
    let x = ones([3])
    let y = silu(x)
    # SiLU(1.0) = 1.0 * sigmoid(1.0) ≈ 0.7311
    let expected = full([3], 0.7311)
    assert_close(y, expected, 0.01, 0.01)

@test
fn test_silu_zero():
    let x = zeros([3])
    let y = silu(x)
    # SiLU(0.0) = 0.0 * sigmoid(0.0) = 0.0
    assert_close(y, zeros([3]), 0.001, 0.001)

@test
fn test_sigmoid_zero():
    let x = zeros([3])
    let y = sigmoid(x)
    # sigmoid(0) = 0.5
    assert_close(y, full([3], 0.5), 0.001, 0.001)

@test
fn test_sigmoid_large_positive():
    let x = full([3], 10.0)
    let y = sigmoid(x)
    # sigmoid(10) ≈ 1.0
    assert_close(y, ones([3]), 0.001, 0.001)

@test
fn test_sigmoid_large_negative():
    let x = full([3], -10.0)
    let y = sigmoid(x)
    # sigmoid(-10) ≈ 0.0
    assert_close(y, zeros([3]), 0.001, 0.001)

@test
fn test_tanh_zero():
    let x = zeros([3])
    let y = tanh(x)
    # tanh(0) = 0
    assert_close(y, zeros([3]), 0.001, 0.001)

@test
fn test_tanh_one():
    let x = ones([3])
    let y = tanh(x)
    # tanh(1.0) ≈ 0.7616
    let expected = full([3], 0.7616)
    assert_close(y, expected, 0.01, 0.01)

@test
fn test_softmax_uniform():
    let x = ones([2, 3])
    let y = softmax(x, 1)
    # All equal inputs → uniform: each = 1/3
    let expected = full([2, 3], 0.333333)
    assert_close(y, expected, 0.001, 0.001)

@test
fn test_softmax_zeros():
    let x = zeros([1, 4])
    let y = softmax(x, 1)
    # All zeros → uniform: each = 1/4
    let expected = full([1, 4], 0.25)
    assert_close(y, expected, 0.001, 0.001)

# ============================================================
# Tensor Operations
# ============================================================

@test
fn test_bias_add():
    let x = ones([2, 3])
    let b = full([3], 10.0)
    let y = bias_add(x, b)
    assert_close(y, full([2, 3], 11.0), 0.001, 0.001)

@test
fn test_bias_add_zeros():
    let x = full([2, 4], 5.0)
    let b = zeros([4])
    let y = bias_add(x, b)
    assert_close(y, full([2, 4], 5.0), 0.001, 0.001)

@test
fn test_slice_1d():
    let x = full([5], 1.0)
    let y = tensor_slice(x, 0, 1, 4)
    assert_eq(y.ndim, 1)

@test
fn test_slice_2d():
    let x = ones([4, 3])
    let y = tensor_slice(x, 0, 0, 2)
    assert_eq(y.ndim, 2)

@test
fn test_cat_1d():
    let a = ones([3])
    let b = full([2], 2.0)
    let tensors = [a, b]
    let c = tensor_cat(tensors, 0)
    assert_eq(c.ndim, 1)

@test
fn test_cat_2d():
    let a = ones([2, 3])
    let b = full([2, 3], 2.0)
    let tensors = [a, b]
    let c = tensor_cat(tensors, 0)
    assert_eq(c.ndim, 2)

@test
fn test_tensor_arithmetic():
    let a = full([3], 2.0)
    let b = full([3], 3.0)
    let c = a + b
    assert_close(c, full([3], 5.0), 0.001, 0.001)

@test
fn test_tensor_multiply():
    let a = full([3], 2.0)
    let b = full([3], 3.0)
    let c = a * b
    assert_close(c, full([3], 6.0), 0.001, 0.001)

@test
fn test_tensor_subtract():
    let a = full([3], 5.0)
    let b = full([3], 3.0)
    let c = a - b
    assert_close(c, full([3], 2.0), 0.001, 0.001)

@test
fn test_tensor_divide():
    let a = full([3], 6.0)
    let b = full([3], 2.0)
    let c = a / b
    assert_close(c, full([3], 3.0), 0.001, 0.001)

@test
fn test_matmul():
    let a = ones([2, 3])
    let b = ones([3, 4])
    let c = a @ b
    # Each element = sum of 3 ones = 3.0
    assert_close(c, full([2, 4], 3.0), 0.001, 0.001)

@test
fn test_reshape():
    let x = ones([2, 3])
    let y = x.reshape([6])
    assert_eq(y.ndim, 1)

@test
fn test_ndim_3d():
    let x = ones([2, 3, 4])
    assert_eq(x.ndim, 3)

@test
fn test_ndim_1d():
    let x = zeros([5])
    assert_eq(x.ndim, 1)

# ============================================================
# NN Layers
# ============================================================

@test
fn test_embedding_lookup():
    let w = ones([10, 4])
    let ids = full([3], 0.0)
    let out = embedding_lookup(w, ids)
    assert_close(out, ones([3, 4]), 0.001, 0.001)

@test
fn test_embedding_lookup_shape():
    let w = ones([10, 8])
    let ids = full([5], 0.0)
    let out = embedding_lookup(w, ids)
    assert_eq(out.ndim, 2)

@test
fn test_layernorm_uniform():
    let x = ones([2, 4])
    let w = ones([4])
    let b = zeros([4])
    let y = layernorm(x, w, b, 0.00001)
    # Normalizing uniform input → zero mean, ~0 output
    assert_close(y, zeros([2, 4]), 0.01, 0.01)

@test
fn test_layernorm_with_bias():
    let x = ones([2, 4])
    let w = ones([4])
    let b = full([4], 5.0)
    let y = layernorm(x, w, b, 0.00001)
    # Normalized uniform = 0, plus bias = 5.0
    assert_close(y, full([2, 4], 5.0), 0.01, 0.01)

@test
fn test_rmsnorm_ones():
    let x = ones([2, 4])
    let w = ones([4])
    let y = rmsnorm(x, w, 0.00001)
    # RMS of ones = 1.0, so output = input * weight / rms ≈ 1.0
    assert_close(y, ones([2, 4]), 0.01, 0.01)

@test
fn test_rmsnorm_scaled():
    let x = ones([2, 4])
    let w = full([4], 2.0)
    let y = rmsnorm(x, w, 0.00001)
    # RMS of ones = 1.0, output = input * weight / rms ≈ 2.0
    assert_close(y, full([2, 4], 2.0), 0.01, 0.01)

# ============================================================
# Dropout
# ============================================================

@test
fn test_dropout_eval_mode():
    let x = ones([2, 3])
    let y = dropout(x, 0.5, 0)
    # In eval mode (training=0), dropout is identity
    assert_close(y, ones([2, 3]), 0.001, 0.001)

@test
fn test_dropout_zero_rate():
    let x = full([3, 4], 3.0)
    let y = dropout(x, 0.0, 1)
    # Zero drop rate → identity even in training
    assert_close(y, full([3, 4], 3.0), 0.001, 0.001)

# ============================================================
# Tokenizer
# ============================================================

@test
fn test_byte_tokenizer_create():
    let tok = byte_tokenizer_new()
    let vocab = tokenizer_vocab_size(tok)
    assert_eq(vocab, 256)

@test
fn test_byte_tokenizer_encode():
    let tok = byte_tokenizer_new()
    let ids = tokenizer_encode(tok, "hi")
    # "h" = 104, "i" = 105 → 2 tokens
    assert_eq(ids.ndim, 1)

@test
fn test_byte_tokenizer_roundtrip():
    let tok = byte_tokenizer_new()
    let ids = tokenizer_encode(tok, "hello")
    let text = tokenizer_decode(tok, ids)
    # Roundtrip should reconstruct the string
    let ids2 = tokenizer_encode(tok, text)
    assert_eq(ids2.ndim, 1)

# ============================================================
# Assert Functions
# ============================================================

@test
fn test_assert_eq_integers():
    assert_eq(5, 5)
    assert_eq(0, 0)
    assert_eq(42, 42)

@test
fn test_assert_close_identical():
    let x = ones([3])
    let y = ones([3])
    assert_close(x, y, 0.001, 0.001)

@test
fn test_assert_close_tolerance():
    let x = full([3], 1.0)
    let y = full([3], 1.009)
    assert_close(x, y, 0.01, 0.01)

# ============================================================
# Shape Operations
# ============================================================

@test
fn test_zeros_shape():
    let x = zeros([2, 3])
    assert_eq(x.ndim, 2)

@test
fn test_ones_shape():
    let x = ones([4, 5, 6])
    assert_eq(x.ndim, 3)

@test
fn test_full_shape():
    let x = full([3, 3], 7.0)
    assert_eq(x.ndim, 2)

@test
fn test_transpose():
    let x = ones([2, 3])
    let y = x.transpose(0, 1)
    assert_eq(y.ndim, 2)
