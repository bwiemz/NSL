# Test that contiguous(expand(...)) + matmul produces correct results
let a = arange(0.0, 4.0)
let a2 = a.reshape([1, 4])
let a_exp = a2.expand([3, 4])
let a_cont = contiguous(a_exp)

let b = ones([4, 2])
let result = a_cont @ b
print(result)
# Each row: sum([0,1,2,3]) = 6.0 for each output column
# Expected: [[6,6],[6,6],[6,6]]

print("expand_matmul: PASS")
